<!-- RENTABILITÉ -->
<div class="page" id="page-rentab">
  <div class="ph"><div class="pt">Calculateur de <span>Rentabilité</span></div><div class="pd">Freelance, dropshipping, investissement.</div></div>
  <div class="tabs2">
    <button class="tab2 active" onclick="swTab('fl',this)">👨‍💻 Freelance</button>
    <button class="tab2" onclick="swTab('ds',this)">📦 Dropshipping</button>
    <button class="tab2" onclick="swTab('inv',this)">💹 Investissement</button>
  </div>
  <div id="tfl">
    <div class="g2">
      <div class="card"><div class="ct">Paramètres</div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Tarif horaire (€)</label><input type="number" id="flt" value="50" oninput="calcFL()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Heures / semaine</label><input type="number" id="flh" value="20" oninput="calcFL()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Semaines / an</label><input type="number" id="fls" value="45" oninput="calcFL()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Charges mensuelles (€)</label><input type="number" id="flc" value="200" oninput="calcFL()"></div>
      </div>
      <div class="card"><div class="ct">Résultats</div><div id="flr"></div><div class="dv"></div><div class="cw2" style="height:180px"><canvas id="chfl"></canvas></div></div>
    </div>
  </div>
  <div id="tds" style="display:none">
    <div class="g2">
      <div class="card"><div class="ct">Paramètres</div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Prix de vente (€)</label><input type="number" id="dsv" value="49" oninput="calcDS()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Coût fournisseur (€)</label><input type="number" id="dsc" value="12" oninput="calcDS()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Budget pub (€)</label><input type="number" id="dsp" value="300" oninput="calcDS()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Coût par clic (€)</label><input type="number" id="dscp" value="0.40" step="0.01" oninput="calcDS()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Taux conversion (%)</label><input type="number" id="dscv" value="2" oninput="calcDS()"></div>
      </div>
      <div class="card"><div class="ct">Résultats</div><div id="dsr"></div><div class="dv"></div><div class="cw2" style="height:180px"><canvas id="chds"></canvas></div></div>
    </div>
  </div>
  <div id="tinv" style="display:none">
    <div class="g2">
      <div class="card"><div class="ct">Paramètres</div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Capital initial (€)</label><input type="number" id="invk" value="5000" oninput="calcINV()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Apport mensuel (€)</label><input type="number" id="invm" value="200" oninput="calcINV()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Rendement annuel (%)</label><input type="number" id="invr" value="8" oninput="calcINV()"></div>
        <div class="fg" style="margin-bottom:.75rem"><label class="fl">Durée (années)</label><input type="number" id="invd" value="10" oninput="calcINV()"></div>
      </div>
      <div class="card"><div class="ct">Projection</div><div id="invr2"></div><div class="dv"></div><div class="cw2" style="height:180px"><canvas id="chinv"></canvas></div></div>
    </div>
  </div>
</div>

