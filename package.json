}

// ══════ IMPORT / EXPORT EXCEL ════════════════════════════════════
let excelWorkbook=null,excelData=[];

function swExcelTab(id,btn){
  ['import','export','templates'].forEach(t=>{const el=document.getElementById('excelTab-'+t);if(el)el.style.display='none';});
  document.querySelectorAll('.tmtab').forEach(b=>b.classList.remove('active'));
  document.getElementById('excelTab-'+id).style.display='block';
  if(btn)btn.classList.add('active');
}

function handleExcelDrop(e){const f=e.dataTransfer.files[0];if(f)handleExcelFileObj(f);}
function handleExcelFile(e){const f=e.target.files[0];if(f)handleExcelFileObj(f);}
function handleExcelFileObj(file){
  if(typeof XLSX==='undefined'){alert('Bibliothèque Excel non chargée. Rechargez la page.');return;}
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      excelWorkbook=XLSX.read(e.target.result,{type:'array'});
      document.getElementById('excelFileName').textContent=file.name;
      const sel=document.getElementById('excelSheetSelect');
      sel.innerHTML=excelWorkbook.SheetNames.map(n=>`<option>${n}</option>`).join('');
      document.getElementById('excelImportResult').style.display='block';
      renderExcelPreview();
    }catch(err){alert('Erreur lecture fichier : '+err.message);}
  };
  reader.readAsArrayBuffer(file);
}
function renderExcelPreview(){
  if(!excelWorkbook)return;
  const sheetName=document.getElementById('excelSheetSelect').value;
  const ws=excelWorkbook.Sheets[sheetName];
  const data=XLSX.utils.sheet_to_json(ws,{header:1,defval:''});
  excelData=data;
  document.getElementById('excelSheetInfo').textContent=`${data.length-1} lignes, ${data[0]?.length||0} colonnes`;
  if(!data.length){document.getElementById('excelPreviewTable').innerHTML='<tr><td>Feuille vide</td></tr>';return;}
  const headers=data[0];
  const rows=data.slice(1,11);
  document.getElementById('excelPreviewTable').innerHTML=`<thead><tr>${headers.map(h=>`<th>${h}</th>`).join('')}</tr></thead><tbody>${rows.map(r=>`<tr>${headers.map((_,i)=>`<td>${r[i]??''}</td>`).join('')}</tr>`).join('')}</tbody>`;
}
function importExcelTo(target){
  if(!excelData||!excelData.length){alert('Aucune donnée chargée.');return;}
  const uid=currentUser?.id||'';
  const headers=excelData[0].map(h=>(h||'').toString().toLowerCase().trim());
  const rows=excelData.slice(1).filter(r=>r.some(v=>v!==''));
  let count=0;
  if(target==='budget'){
    const existing=JSON.parse(localStorage.getItem('ph_budget_'+uid)||'[]');
    const iDesc=headers.findIndex(h=>['description','desc','libellé','libelle','nom'].includes(h));
    const iAmt=headers.findIndex(h=>['montant','amount','prix','somme','valeur'].includes(h));
    const iType=headers.findIndex(h=>['type','sens'].includes(h));
    const iCat=headers.findIndex(h=>['categorie','catégorie','category','cat'].includes(h));
    const newTxs=rows.map(r=>({id:Date.now()+Math.random(),d:r[iDesc]||'Import Excel',a:Math.abs(parseFloat(r[iAmt])||0),type:iType>=0?((r[iType]||'').toString().toLowerCase().includes('dep')||parseFloat(r[iAmt])<0?'depense':'revenu'):'revenu',cat:r[iCat]||'Autre',date:new Date().toLocaleDateString('fr-FR')})).filter(t=>t.a>0);
    localStorage.setItem('ph_budget_'+uid,JSON.stringify([...existing,...newTxs]));
    rBudget();count=newTxs.length;
  } else if(target==='crm'){
    const existing=JSON.parse(localStorage.getItem('ph_crm_'+uid)||'[]');
    const iName=headers.findIndex(h=>['nom','name','contact'].includes(h));
    const iCo=headers.findIndex(h=>['entreprise','company','société','societe'].includes(h));
    const iEmail=headers.findIndex(h=>['email','mail','courriel'].includes(h));
    const iPhone=headers.findIndex(h=>['telephone','téléphone','phone','tel'].includes(h));
    const iStatus=headers.findIndex(h=>['statut','status','type'].includes(h));
    const iVal=headers.findIndex(h=>['valeur','value','ca','chiffre'].includes(h));
    const newContacts=rows.filter(r=>r[iName]).map(r=>({id:'crm_'+Date.now()+Math.random(),name:r[iName]||'',company:r[iCo]||'',email:r[iEmail]||'',phone:r[iPhone]||'',status:r[iStatus]||'prospect',value:parseFloat(r[iVal])||0,createdAt:new Date().toISOString(),notes:[]}));
    localStorage.setItem('ph_crm_'+uid,JSON.stringify([...existing,...newContacts]));
    crmContacts=[...existing,...newContacts];renderCRM();count=newContacts.length;
  } else if(target==='hr'){
    const existing=JSON.parse(localStorage.getItem('ph_hr_emp_'+uid)||'[]');
    const iName=headers.findIndex(h=>['nom','name','employé','employe','prenom'].includes(h));
    const iPost=headers.findIndex(h=>['poste','post','fonction','titre','role'].includes(h));
    const iDept=headers.findIndex(h=>['département','departement','dept','service'].includes(h));
    const iSal=headers.findIndex(h=>['salaire','salary','remuneration','rémunération'].includes(h));
    const newEmps=rows.filter(r=>r[iName]).map(r=>({id:'hr_'+Date.now()+Math.random(),name:r[iName]||'',post:r[iPost]||'',dept:r[iDept]||'',salary:parseFloat(r[iSal])||0,start:new Date().toISOString().split('T')[0],status:'actif'}));
    localStorage.setItem('ph_hr_emp_'+uid,JSON.stringify([...existing,...newEmps]));
    hrEmployees=[...existing,...newEmps];renderHR();count=newEmps.length;
  } else if(target==='produits'){
    const iName=headers.findIndex(h=>['nom','name','produit','article'].includes(h));
    const iCat=headers.findIndex(h=>['categorie','catégorie','cat','category'].includes(h));
    const iAchat=headers.findIndex(h=>['achat','achat_prix','prix_achat','cost'].includes(h));
    const iVente=headers.findIndex(h=>['vente','vente_prix','prix_vente','price'].includes(h));
    const newProds=rows.filter(r=>r[iName]).map(r=>({n:r[iName]||'',cat:r[iCat]||'Autre',a:parseFloat(r[iAchat])||0,v:parseFloat(r[iVente])||0}));
    prods=[...newProds,...prods];renderProd();count=newProds.length;
  }
  showA('excelImportAlert','✅ '+count+' lignes importées avec succès dans '+{budget:'le Budget',crm:'le CRM',hr:'les RH',produits:'les Produits'}[target]+'  !','aok');
}

function exportToExcel(type){
  if(typeof XLSX==='undefined'){alert('Bibliothèque Excel non chargée. Rechargez la page.');return;}
  const uid=currentUser?.id||'';
  const wb=XLSX.utils.book_new();
  if(type==='budget'||type==='all'){
    const txs=JSON.parse(localStorage.getItem('ph_budget_'+uid)||'[]');
    const data=[['Description','Catégorie','Type','Montant (€)','Date'],...txs.map(t=>[t.d||'—',t.cat||'—',t.type,t.a,t.date||'—'])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(data),'Budget');
  }
  if(type==='devis'||type==='all'){
    const data=[['ID','Client','Objet','Total HT (€)','Date','Statut'],...(dvList||[]).map(d=>[d.id,d.c,d.o,d.tot,d.date,d.s])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(data),'Devis');
  }
  if(type==='crm'||type==='all'){
    const data=[['Nom','Entreprise','Email','Téléphone','Statut','Valeur (€)'],...crmContacts.map(c=>[c.name,c.company||'',c.email||'',c.phone||'',c.status,c.value||0])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(data),'CRM');
  }
  if(type==='hr'||type==='all'){
    const data=[['Nom','Poste','Département','Salaire brut (€)','Statut','Date entrée'],...hrEmployees.map(e=>[e.name,e.post||'',e.dept||'',e.salary||0,e.status||'',e.start||''])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(data),'RH');
  }
  if(type==='kpis'||type==='all'){
    const kpis=JSON.parse(localStorage.getItem('ph_kpis_'+uid)||'[]');
    const data=[['Objectif','Cible','Actuel','Unité','Progression (%)'],...kpis.map(k=>[k.nom,k.cible,k.actuel,k.unit||'',Math.round(k.actuel/k.cible*100)])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(data),'KPIs');
  }
  if(!wb.SheetNames.length){alert('Aucune donnée à exporter. Chargez des données démo d'abord.');return;}
  const fname=type==='all'?'ProHub_Export_Complet_'+new Date().getFullYear()+'.xlsx':'ProHub_'+type+'_'+new Date().getFullYear()+'.xlsx';
  XLSX.writeFile(wb,fname);
}

function downloadTemplate(type){
  if(typeof XLSX==='undefined'){alert('Bibliothèque Excel non chargée.');return;}
  const wb=XLSX.utils.book_new();
  const templates={
    budget:{name:'Budget',headers:['description','catégorie','type (revenu/depense)','montant','date'],example:[['Facture client Acme','Salaire / Freelance','revenu',4500,'15/03/2025'],['Loyer bureau','Logement','depense',1200,'01/03/2025']]},
    crm:{name:'CRM',headers:['nom','entreprise','email','téléphone','statut (prospect/lead/client)','valeur'],example:[['Jean Dupont','Acme Corp','jean@acme.fr','06 12 34 56 78','client',15000]]},
    hr:{name:'RH',headers:['nom','poste','département','salaire','statut (actif/essai/conge)'],example:[['Marie Martin','Développeur','Tech',4200,'actif']]},
    produits:{name:'Produits',headers:['nom','categorie','achat_prix','vente_prix'],example:[['Coque iPhone','High-tech',3,18]]}
  };
  const t=templates[type];
  if(!t)return;
  const data=[t.headers,...t.example,['-- Ajoutez vos données à partir de la ligne suivante --']];
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(data),'Modèle '+t.name);
  XLSX.writeFile(wb,'ProHub_Modele_'+t.name+'.xlsx');
}

