// ══════ BUDGET PRÉVISIONNEL ══════════════════════════════════════
const BUDGET_ROWS=['CA prévisionnel','CA réel','Charges prévues','Charges réelles','Résultat prévu','Résultat réel'];
let budgetEntData={};

function initBudgetEnt(){try{budgetEntData=JSON.parse(localStorage.getItem('ph_budgetent_'+(currentUser?.id||''))||'{}');}catch{budgetEntData={};}renderBudgetEnt();}
function saveBudgetEnt(){localStorage.setItem('ph_budgetent_'+(currentUser?.id||''),JSON.stringify(budgetEntData));alert('✅ Budget sauvegardé !');}
function getBudgetVal(row,mi){return budgetEntData[row]?.[mi]||0;}
function setBudgetVal(row,mi,val){if(!budgetEntData[row])budgetEntData[row]={};budgetEntData[row][mi]=parseFloat(val)||0;updateBudgetCalculated();renderBudgetEntCharts();}
function updateBudgetCalculated(){
  for(let mi=0;mi<12;mi++){
    const rp=getBudgetVal('CA prévisionnel',mi);const rr=getBudgetVal('CA réel',mi);
    const cp=getBudgetVal('Charges prévues',mi);const cr=getBudgetVal('Charges réelles',mi);
    if(!budgetEntData['Résultat prévu'])budgetEntData['Résultat prévu']={};
    if(!budgetEntData['Résultat réel'])budgetEntData['Résultat réel']={};
    budgetEntData['Résultat prévu'][mi]=rp-cp;
    budgetEntData['Résultat réel'][mi]=rr-cr;
  }
}
function renderBudgetEnt(){
  const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  const headEl=document.getElementById('budgetEntHead');
  const bodyEl=document.getElementById('budgetEntBody');
  if(!headEl||!bodyEl)return;
  headEl.innerHTML='<th style="padding:.6rem .75rem;text-align:left;color:var(--muted2);font-size:.72rem">Ligne</th>'+months.map(m=>`<th style="padding:.6rem .75rem;text-align:right;color:var(--muted2);font-size:.72rem;min-width:80px">${m}</th>`).join('')+'<th style="padding:.6rem .75rem;text-align:right;color:var(--muted2);font-size:.72rem">Total</th>';
  const rowColors={0:'var(--a3)',1:'rgba(0,206,201,.6)',2:'#ff7070',3:'rgba(255,70,102,.6)',4:'var(--gold)',5:'rgba(253,203,110,.6)'};
  const editable=[0,1,2,3];
  bodyEl.innerHTML=BUDGET_ROWS.map((row,ri)=>{
    const total=months.reduce((_,__,mi)=>_+getBudgetVal(row,mi),0);
    const cells=months.map((_,mi)=>{
      const v=getBudgetVal(row,mi);
      if(editable.includes(ri))return`<td style="padding:.4rem .5rem;text-align:right"><input type="number" value="${v||''}" placeholder="0" onchange="setBudgetVal('${row}',${mi},this.value)" style="width:72px;text-align:right;font-size:.78rem;padding:3px 6px;background:var(--bg3);border:1px solid var(--border);color:var(--text);border-radius:4px"></td>`;
      return`<td style="padding:.6rem .75rem;text-align:right;font-size:.82rem;font-weight:700;color:${rowColors[ri]}">${v?v.toLocaleString('fr-FR'):''}</td>`;
    }).join('');
    const totalColor=rowColors[ri];
    return`<tr style="border-bottom:1px solid var(--border)${[4,5].includes(ri)?';background:rgba(255,255,255,.02)':''}"><td style="padding:.6rem .75rem;font-size:.8rem;font-weight:600;color:${totalColor};white-space:nowrap">${row}</td>${cells}<td style="padding:.6rem .75rem;text-align:right;font-weight:800;font-size:.85rem;color:${totalColor}">${total?total.toLocaleString('fr-FR')+'€':''}</td></tr>`;
  }).join('');
  renderBudgetEntCharts();
}
function renderBudgetEntCharts(){
  const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  setTimeout(()=>{
    if(chBudEnt1)chBudEnt1.destroy();
    const el1=document.getElementById('chBudgetEnt1');if(!el1)return;
    chBudEnt1=new Chart(el1.getContext('2d'),{type:'bar',data:{labels:months,datasets:[{label:'CA prévu',data:months.map((_,i)=>getBudgetVal('CA prévisionnel',i)),backgroundColor:'rgba(108,92,231,0.5)',borderColor:'#6c5ce7',borderWidth:1,borderRadius:3},{label:'CA réel',data:months.map((_,i)=>getBudgetVal('CA réel',i)),backgroundColor:'rgba(0,206,201,0.6)',borderColor:'#00cec9',borderWidth:1,borderRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a'}}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}});
    if(chBudEnt2)chBudEnt2.destroy();
    const el2=document.getElementById('chBudgetEnt2');if(!el2)return;
    chBudEnt2=new Chart(el2.getContext('2d'),{type:'line',data:{labels:months,datasets:[{label:'Résultat prévu',data:months.map((_,i)=>getBudgetVal('Résultat prévu',i)),borderColor:'#fdcb6e',backgroundColor:'rgba(253,203,110,0.08)',tension:0.4,pointRadius:3,fill:true},{label:'Résultat réel',data:months.map((_,i)=>getBudgetVal('Résultat réel',i)),borderColor:'#00cec9',backgroundColor:'rgba(0,206,201,0.05)',tension:0.4,pointRadius:3,fill:true}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a'}}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}});
  },100);
}
function loadDemoBudget(){
  const revs=[12000,13500,11000,15000,14200,16800,13000,17500,15800,18000,16500,20000];
  const deps=[8000,8500,7800,9200,8900,10000,8200,10500,9800,11000,9500,12000];
  revs.forEach((v,i)=>{if(!budgetEntData['CA prévisionnel'])budgetEntData['CA prévisionnel']={};budgetEntData['CA prévisionnel'][i]=v;});
  revs.forEach((v,i)=>{if(!budgetEntData['CA réel'])budgetEntData['CA réel']={};budgetEntData['CA réel'][i]=Math.round(v*(0.85+Math.random()*0.3));});
  deps.forEach((v,i)=>{if(!budgetEntData['Charges prévues'])budgetEntData['Charges prévues']={};budgetEntData['Charges prévues'][i]=v;});
  deps.forEach((v,i)=>{if(!budgetEntData['Charges réelles'])budgetEntData['Charges réelles']={};budgetEntData['Charges réelles'][i]=Math.round(v*(0.9+Math.random()*0.2));});
  updateBudgetCalculated();renderBudgetEnt();
}
function exportBudgetExcel(){
  if(typeof XLSX==='undefined'){alert('Bibliothèque Excel non chargée.');return;}
  const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  const wb=XLSX.utils.book_new();
  const data=[['Ligne',...months,'Total'],...BUDGET_ROWS.map(row=>{const vals=months.map((_,i)=>getBudgetVal(row,i));return[row,...vals,vals.reduce((s,v)=>s+v,0)];})];
