let selT='insta',currentTone='Professionnel';
function selType(el){document.querySelectorAll('.cb').forEach(b=>b.classList.remove('active'));el.classList.add('active');selT=el.dataset.t;}
function selTone(el){document.querySelectorAll('.tb').forEach(b=>b.classList.remove('active'));el.classList.add('active');currentTone=el.textContent;}
const tmpl={insta:(d,t)=>`✨ ${t==='Enthousiaste'?'WOW ! ':t==='Humoristique'?'Alerte 🚨 : ':''}${d}\n\n✅ Qualité premium\n✅ Livraison rapide\n✅ ${t==='Luxe'?"Expérience d'exception":'Satisfait ou remboursé'}\n\n👉 Lien en bio !\n\n#entrepreneur #france #business #${d.split(' ')[0].toLowerCase()}`,desc:(d,t)=>`${d}\n\n✦ Qualité supérieure\n✦ Livraison 48h\n✦ Service 7j/7\n\n${t==='Luxe'?"💎 Un produit d'exception.":'🛒 Commandez maintenant !'}`,email:(d,t)=>`Objet: 🎁 Offre exclusive — ${d}\n\nBonjour,\n\n${d}\n\n✦ Qualité garantie\n✦ Livraison offerte dès 50€\n✦ Retours gratuits\n\nCordialement,\nL'équipe`,slogan:(d,t)=>`5 slogans pour "${d}" :\n\n1. "La qualité que vous cherchiez."\n2. "${d} — Le meilleur choix."\n3. "L'excellence, sans compromis."\n4. "Votre satisfaction, notre obsession."\n5. "Plus qu'un produit — une expérience."`,google:(d,t)=>`📍 À propos\n\n${d}\n\n⭐ Des centaines de clients nous font confiance\n🕐 Lun–Ven 9h–19h\n📞 Disponible 7j/7`,bio:(d,t)=>`${t==='Décontracté'?'👋 Salut !':'✨ Bienvenue !'} Je suis ${d}.\n\n🎯 Toujours à votre service\n📦 Livraison rapide\n💬 DM ouvert\n\n👇 Lien en bio`};
function genContent(){const d=document.getElementById('cdesc').value.trim();if(!d){document.getElementById('cdesc').focus();return;}const btn=document.getElementById('gb');btn.textContent='⏳...';btn.disabled=true;setTimeout(()=>{document.getElementById('cout').textContent=(tmpl[selT]||tmpl.insta)(d,currentTone);document.getElementById('crc').style.display='block';btn.textContent='✨ Générer le contenu';btn.disabled=false;},600);}
function doCopy(){navigator.clipboard.writeText(document.getElementById('cout').textContent);document.querySelector('.cpb').textContent='✅ Copié !';setTimeout(()=>document.querySelector('.cpb').textContent='Copier',1500);}

// CRYPTO
let crL=false,crP={},crCh;
const crM={bitcoin:{sym:'BTC',name:'Bitcoin',ic:'₿'},ethereum:{sym:'ETH',name:'Ethereum',ic:'Ξ'},solana:{sym:'SOL',name:'Solana',ic:'◎'},binancecoin:{sym:'BNB',name:'BNB',ic:'B'},cardano:{sym:'ADA',name:'Cardano',ic:'₳'},ripple:{sym:'XRP',name:'XRP',ic:'X'},dogecoin:{sym:'DOGE',name:'Dogecoin',ic:'Ð'},polkadot:{sym:'DOT',name:'Polkadot',ic:'●'}};
async function loadCrypto(){document.getElementById('crl').style.display='flex';document.getElementById('crg').style.display='none';try{const res=await fetch('https://api.coingecko.com/api/v3/simple/price?ids='+Object.keys(crM).join(',')+'&vs_currencies=eur&include_24hr_change=true');const data=await res.json();crP=data;document.getElementById('crg').innerHTML=Object.keys(crM).map(c=>{if(!data[c])return'';const m=crM[c],p=data[c].eur,ch=(data[c].eur_24h_change||0).toFixed(2),pos=ch>=0;return`<div class="cc" onclick="showCrCh('${c}')"><div class="sym">${m.ic} ${m.sym}</div><div class="cn3">${m.name}</div><div class="pr3">${p>=1000?p.toLocaleString('fr-FR',{maximumFractionDigits:2}):p.toFixed(4)} €</div><div class="ch3" style="color:${pos?'var(--a3)':'#ff7070'}">${pos?'▲':'▼'} ${Math.abs(ch)}%</div></div>`;}).join('');document.getElementById('crl').style.display='none';document.getElementById('crg').style.display='grid';crL=true;document.getElementById('crt').textContent='Mis à jour: '+new Date().toLocaleTimeString('fr-FR');}catch(e){document.getElementById('crl').innerHTML='<span style="color:#ff7070">⚠️ Erreur API — Réessaie dans quelques secondes</span>';}}
function showCrCh(c){document.getElementById('crcc').style.display='block';document.getElementById('crct').textContent=crM[c].name+' — 7 jours';const p=crP[c]?.eur||100,v=p*0.04,vals=['J-6','J-5','J-4','J-3','J-2','J-1','Auj'].map((_,i)=>p+(Math.random()-.48)*v*(i+1));vals[6]=p;if(crCh)crCh.destroy();crCh=new Chart(document.getElementById('chcr').getContext('2d'),{type:'line',data:{labels:['J-6','J-5','J-4','J-3','J-2','J-1','Auj'],datasets:[{label:crM[c].sym,data:vals,borderColor:'#00cec9',backgroundColor:'#00cec912',tension:0.4,pointRadius:4,fill:true}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a'}}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}})}
function calcPort(){const c=document.getElementById('pc2').value,q=parseFloat(document.getElementById('pq').value),b=parseFloat(document.getElementById('pb2').value);if(!q||!b){alert('Remplis tous les champs');return;}if(!crP[c]){alert("Charge d'abord les prix !");return;}const cur=crP[c].eur,inv=q*b,now2=q*cur,pnl=now2-inv,pct=((pnl/inv)*100).toFixed(2),pos=pnl>=0;document.getElementById('prr').style.display='block';document.getElementById('prr').innerHTML=`<div class="ct">P&L</div><div style="display:flex;flex-direction:column;gap:.8rem"><div><div style="font-size:.72rem;color:var(--muted2)">Investi</div><div style="font-size:1.3rem;font-weight:800">${inv.toLocaleString('fr-FR',{maximumFractionDigits:2})} €</div></div><div><div style="font-size:.72rem;color:var(--muted2)">Valeur actuelle</div><div style="font-size:1.3rem;font-weight:800">${now2.toLocaleString('fr-FR',{maximumFractionDigits:2})} €</div></div><div><div style="font-size:.72rem;color:var(--muted2)">P&L</div><div style="font-size:1.6rem;font-weight:800;color:${pos?'var(--a3)':'#ff7070'}">${pos?'+':''}${pnl.toLocaleString('fr-FR',{maximumFractionDigits:2})} € (${pos?'+':''}${pct}%)</div></div></div>`;}

// RENTABILITÉ
let chFL,chDS,chINV;
function swTab(id,btn){['fl','ds','inv'].forEach(t=>document.getElementById('t'+t).style.display='none');document.querySelectorAll('.tab2').forEach(b=>b.classList.remove('active'));document.getElementById('t'+id).style.display='block';btn.classList.add('active');}
function Rw(l,v,col){return`<div style="display:flex;justify-content:space-between;padding:.5rem 0;border-bottom:1px solid rgba(255,255,255,0.04)"><span style="color:var(--muted2);font-size:.83rem">${l}</span><span style="font-weight:700${col?';color:'+col:''}">${v}</span></div>`;}
function calcFL(){const t=parseFloat(document.getElementById('flt')?.value||50),h=parseFloat(document.getElementById('flh')?.value||20),s=parseFloat(document.getElementById('fls')?.value||45),c=parseFloat(document.getElementById('flc')?.value||200);const caA=t*h*s,caM=caA/12,chA=c*12,nA=caA-chA,nM=nA/12;const el=document.getElementById('flr');if(!el)return;el.innerHTML=Rw('CA mensuel',caM.toFixed(0)+' €','var(--a3)')+Rw('CA annuel',caA.toFixed(0)+' €','var(--a3)')+Rw('Charges annuelles',chA.toFixed(0)+' €','#ff7070')+Rw('Net mensuel',nM.toFixed(0)+' €',nM>2000?'var(--a3)':'var(--gold)');if(chFL)chFL.destroy();const el2=document.getElementById('chfl');if(!el2)return;chFL=new Chart(el2.getContext('2d'),{type:'doughnut',data:{labels:['Net','Charges'],datasets:[{data:[Math.max(0,nA),chA],backgroundColor:['#00cec9','#ff4466'],borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'bottom',labels:{color:'#7a7a9a',font:{size:10}}}}}})}
function calcDS(){const v=parseFloat(document.getElementById('dsv')?.value||49),c=parseFloat(document.getElementById('dsc')?.value||12),p=parseFloat(document.getElementById('dsp')?.value||300),cp=parseFloat(document.getElementById('dscp')?.value||0.4),cv=parseFloat(document.getElementById('dscv')?.value||2)/100;const cl=p/cp,vt=Math.floor(cl*cv),ca=vt*v,cpr=vt*c,pr=ca-cpr-p,roi=p>0?((pr/p)*100).toFixed(1):0;const el=document.getElementById('dsr');if(!el)return;el.innerHTML=Rw('Clics estimés',cl.toFixed(0))+Rw('Ventes/mois',vt+' commandes')+Rw('CA mensuel',ca.toFixed(0)+' €')+Rw('Profit mensuel',pr.toFixed(0)+' €',pr>0?'var(--a3)':'#ff7070')+Rw('ROI publicité',roi+'%',roi>0?'var(--a3)':'#ff7070');if(chDS)chDS.destroy();const el2=document.getElementById('chds');if(!el2)return;chDS=new Chart(el2.getContext('2d'),{type:'bar',data:{labels:['CA','Coût prod','Pub','Profit'],datasets:[{data:[ca,cpr,p,Math.max(0,pr)],backgroundColor:['#7c3aed66','#ff446666','#fdcb6e66','#00cec966'],borderColor:['#7c3aed','#ff4466','#fdcb6e','#00cec9'],borderWidth:1,borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}})}
function calcINV(){const k=parseFloat(document.getElementById('invk')?.value||5000),m=parseFloat(document.getElementById('invm')?.value||200),r=parseFloat(document.getElementById('invr')?.value||8)/100,d=parseInt(document.getElementById('invd')?.value||10);const rm=r/12;let val=k;const vals=[k],invs=[k];for(let i=1;i<=d*12;i++){val=val*(1+rm)+m;if(i%12===0){vals.push(Math.round(val));invs.push(k+m*i);}}const ti=k+m*d*12,g=vals[vals.length-1]-ti;const el=document.getElementById('invr2');if(!el)return;el.innerHTML=Rw('Capital investi total',ti.toLocaleString('fr-FR')+' €')+Rw('Valeur finale',vals[vals.length-1].toLocaleString('fr-FR')+' €','var(--a3)')+Rw('Intérêts générés','+'+g.toLocaleString('fr-FR')+' €','var(--a3)');if(chINV)chINV.destroy();const el2=document.getElementById('chinv');if(!el2)return;chINV=new Chart(el2.getContext('2d'),{type:'line',data:{labels:Array.from({length:d+1},(_,i)=>'An '+i),datasets:[{label:'Valeur portefeuille',data:vals,borderColor:'#00cec9',backgroundColor:'#00cec910',tension:0.4,fill:true,pointRadius:2},{label:'Investi',data:invs,borderColor:'#7c3aed',backgroundColor:'transparent',tension:0.1,borderDash:[5,5],pointRadius:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a',font:{size:10}}}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}})}

