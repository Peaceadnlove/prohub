// ═══ V4 SETTINGS ═══════════════════════════════════════════════════════════
let pendingEmailChange=null;

function swSettingsTab(id,btn){
  ['profil','securite','notifs','export','integrations','danger'].forEach(t=>{const el=document.getElementById('stab-'+t);if(el)el.style.display='none';});
  document.querySelectorAll('.stab').forEach(b=>b.classList.remove('active'));
  document.getElementById('stab-'+id).style.display='block';
  btn.classList.add('active');
}

function renderSettingsProfile(){
  if(!currentUser)return;
  const rL={free:'🆓 Gratuit',premium:'⭐ Premium',premium2:'💎 Premium+',enterprise:'🏢 Entreprise',admin:'👑 Admin'};
  const av=document.getElementById('settingsAvatar');if(av)av.textContent=currentUser.name.charAt(0).toUpperCase();
  const sn=document.getElementById('settingsName');if(sn)sn.textContent=currentUser.name;
  const sp=document.getElementById('settingsPlan');if(sp)sp.textContent=rL[currentUser.role]||currentUser.role;
  const ni=document.getElementById('settingNameInput');if(ni)ni.value=currentUser.name;
  const ced=document.getElementById('currentEmailDisplay');if(ced)ced.textContent=currentUser.email;
  const iid=document.getElementById('infoId');if(iid)iid.textContent=currentUser.id||'—';
  const ip=document.getElementById('infoPlan');if(ip)ip.textContent=rL[currentUser.role]||currentUser.role;
  const id2=document.getElementById('infoDate');if(id2)id2.textContent=currentUser.createdAt?new Date(currentUser.createdAt).toLocaleDateString('fr-FR'):'—';
  const iv=document.getElementById('infoVerified');if(iv)iv.innerHTML=currentUser.emailVerified?'<span style="color:var(--a3)">✅ Oui</span>':'<span style="color:#ff7070">❌ Non</span>';
}

async function saveName(){
  const n=document.getElementById('settingNameInput').value.trim();
  if(!n){showA('profileAlert','Nom requis.','aer');return;}
  const r=await API.patch('/api/auth/update-name',{name:n});
  if(r.error){showA('profileAlert',r.error,'aer');return;}
  currentUser.name=n;
  document.getElementById('userAv').textContent=n.charAt(0).toUpperCase();
  document.getElementById('userName').textContent=n;
  renderSettingsProfile();
  showA('profileAlert','✅ Nom mis à jour !','aok');
}

async function requestEmailChange(){
  const newEmail=document.getElementById('newEmailInput').value.trim();
  const pwd=document.getElementById('emailChangePwd').value;
  if(!newEmail||!pwd){showA('emailAlert','Email et mot de passe requis.','aer');return;}
  if(newEmail===currentUser.email){showA('emailAlert','C\'est déjà ton email actuel.','aer');return;}
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(newEmail)){showA('emailAlert','Email invalide.','aer');return;}
  const r=await API.post('/api/auth/request-email-change',{newEmail,password:pwd});
  if(r.error){showA('emailAlert',r.error,'aer');return;}
  pendingEmailChange={newEmail};
  document.getElementById('modalEmailVerifyTxt').textContent='Code envoyé sur '+newEmail;
  document.querySelectorAll('#emailCodeInputs .code-input').forEach(i=>i.value='');
  document.getElementById('modalEmailVerify').style.display='flex';
  setTimeout(()=>document.querySelectorAll('#emailCodeInputs .code-input')[0].focus(),100);
}

function moveCodeEC(el,next){if(el.value&&next<=6){const inputs=document.querySelectorAll('#emailCodeInputs .code-input');if(inputs[next])inputs[next].focus();}checkAutoEC();}
function backCodeEC(e,el,prev){if(e.key==='Backspace'&&!el.value&&prev>=0)document.querySelectorAll('#emailCodeInputs .code-input')[prev].focus();}
function checkAutoEC(){const code=[...document.querySelectorAll('#emailCodeInputs .code-input')].map(i=>i.value).join('');if(code.length===6)doVerifyEmailChange();}

async function doVerifyEmailChange(){
  const code=[...document.querySelectorAll('#emailCodeInputs .code-input')].map(i=>i.value).join('');
  if(code.length!==6){showModalAlert('modalEmailAlert','Entre le code à 6 chiffres.','aer');return;}
  document.getElementById('btnEmailVerify').disabled=true;
  const r=await API.post('/api/auth/verify-email-change',{email:pendingEmailChange.newEmail,code});
  document.getElementById('btnEmailVerify').disabled=false;
  if(r.error){showModalAlert('modalEmailAlert',r.error,'aer');document.querySelectorAll('#emailCodeInputs .code-input').forEach(i=>i.value='');return;}
  localStorage.setItem('ph_token',r.token);
  currentUser.email=pendingEmailChange.newEmail;
  document.getElementById('userEmail').textContent=currentUser.email;
  pendingEmailChange=null;
  closeModal('modalEmailVerify');
  renderSettingsProfile();
  showA('emailAlert','✅ Email mis à jour avec succès !','aok');
}

function toggleSw(el){el.classList.toggle('on');}

function exportData(type){
  const uid=currentUser?.id||'user';
  let content,filename;
  try{
    if(type==='budget'){const txs=JSON.parse(localStorage.getItem('ph_budget_'+uid)||'[]');if(!txs.length){alert('Aucune transaction.');return;}content='Description,Catégorie,Type,Montant\n'+txs.map(t=>`"${t.d}","${t.cat}","${t.type}","${t.a}"`).join('\n');filename='prohub_budget.csv';}
    else if(type==='notes'){const notes=JSON.parse(localStorage.getItem('ph_notes_'+uid)||'[]');if(!notes.length){alert('Aucune note.');return;}content=notes.map(n=>`# ${n.titre} [${n.cat}]\n${n.content||''}\n---`).join('\n\n');filename='prohub_notes.txt';}
    else if(type==='kpis'){const kpis=JSON.parse(localStorage.getItem('ph_kpis_'+uid)||'[]');if(!kpis.length){alert('Aucun KPI.');return;}content='Objectif,Cible,Actuel,Unité\n'+kpis.map(k=>`"${k.nom}","${k.cible}","${k.actuel}","${k.unit||''}"`).join('\n');filename='prohub_kpis.csv';}
    else if(type==='agenda'){const evs=JSON.parse(localStorage.getItem('ph_agenda_'+uid)||'[]');if(!evs.length){alert('Aucun événement.');return;}content='Titre,Date,Type\n'+evs.map(e=>`"${e.titre}","${e.date}","${e.type}"`).join('\n');filename='prohub_agenda.csv';}
    else if(type==='devis'){if(!dvList.length){alert('Aucun devis.');return;}content='ID,Client,Objet,Total,Date,Statut\n'+dvList.map(d=>`"${d.id}","${d.c}","${d.o}","${d.tot}","${d.date}","${d.s}"`).join('\n');filename='prohub_devis.csv';}
    else{const all={user:{name:currentUser.name,email:currentUser.email,plan:currentUser.role},budget:JSON.parse(localStorage.getItem('ph_budget_'+uid)||'[]'),notes:JSON.parse(localStorage.getItem('ph_notes_'+uid)||'[]'),kpis:JSON.parse(localStorage.getItem('ph_kpis_'+uid)||'[]'),agenda:JSON.parse(localStorage.getItem('ph_agenda_'+uid)||'[]'),exported:new Date().toISOString()};content=JSON.stringify(all,null,2);filename='prohub_export_complet.json';}
    const blob=new Blob([content],{type:'text/plain;charset=utf-8'});
    const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=filename;a.click();
  }catch(e){alert('Erreur export : '+e.message);}
}

function clearLocalData(){
  if(!confirm('⚠️ Supprimer toutes les données locales ? Irréversible.'))return;
  const uid=currentUser?.id||'user';
  ['ph_budget_','ph_notes_','ph_kpis_','ph_agenda_','ph_team_'].forEach(k=>localStorage.removeItem(k+uid));
  alert('✅ Données locales effacées.');
  rBudget();initNotes();initKpis();initAgenda();
}

async function deleteAccount(){
  if(!confirm('⚠️ SUPPRIMER DÉFINITIVEMENT votre compte ?'))return;
  if(prompt('Tapez SUPPRIMER pour confirmer :')||''!=='SUPPRIMER'){alert('Annulé.');return;}
  const r=await API.del('/api/auth/account');
  if(r.error){alert('Erreur : '+r.error);return;}
  doLogout();
}

// ═══ WORKSPACE ═════════════════════════════════════════════════════════════
let wsData={name:'Mon Entreprise',members:[],pending:[],activity:[]};

function initWorkspace(){
  const uid=currentUser?.id||'user';
  try{wsData=JSON.parse(localStorage.getItem('ph_workspace_'+uid)||'null')||{name:'Mon Entreprise',id:'ws_'+uid,members:[{id:uid,name:currentUser.name,email:currentUser.email,role:'owner',joinedAt:new Date().toISOString()}],pending:[],activity:[{text:'Espace créé',time:new Date().toISOString(),ico:'🏢'}]};}
  catch{wsData={name:'Mon Entreprise',id:'ws_'+uid,members:[{id:uid,name:currentUser.name,email:currentUser.email,role:'owner',joinedAt:new Date().toISOString()}],pending:[],activity:[]};}
  saveWs();renderWorkspace();
}
function saveWs(){localStorage.setItem('ph_workspace_'+(currentUser?.id||'user'),JSON.stringify(wsData));}
function renderWorkspace(){
  document.getElementById('wsName').textContent=wsData.name;
  document.getElementById('wsId').textContent=wsData.id||'—';
  document.getElementById('wsMemberCount').textContent=wsData.members.length+' membre'+(wsData.members.length>1?'s':'');
  const colors=['#6c5ce7','#00cec9','#fdcb6e','#a29bfe','#fd79a8'];
  const roleLabel={owner:'Propriétaire',admin2:'Admin',member:'Membre',viewer:'Lecteur'};
  const roleCls={owner:'role-owner',admin2:'role-admin2',member:'role-member',viewer:'role-viewer'};
  document.getElementById('wsMemberList').innerHTML=wsData.members.map((m,i)=>`<div class="member-card"><div class="member-av" style="background:${colors[i%colors.length]}">${m.name.charAt(0).toUpperCase()}</div><div class="member-info"><div class="member-name">${m.name}</div><div class="member-email">${m.email}</div></div><span class="member-role-badge ${roleCls[m.role]||'role-member'}">${roleLabel[m.role]||m.role}</span>${m.role!=='owner'?`<button class="btn bd bsm" onclick="removeWsMember('${m.id}')">✕</button>`:''}</div>`).join('')||'<div class="empty" style="padding:1.5rem">Aucun membre</div>';
  document.getElementById('wsPendingList').innerHTML=wsData.pending.map(p=>`<div class="user-row"><div class="ua-info"><div style="font-size:.875rem;font-weight:600">${p.email}</div><div style="font-size:.73rem;color:var(--muted2)">${p.role} • ${new Date(p.invitedAt).toLocaleDateString('fr-FR')}</div></div><button class="btn bd bsm" onclick="cancelInvite('${p.email}')">Annuler</button></div>`).join('')||'<div class="empty" style="padding:1.5rem">Aucune invitation</div>';
  document.getElementById('wsActivityLog').innerHTML=wsData.activity.slice(0,8).map(a=>`<div class="activity-item"><div class="act-ico">${a.ico||'📋'}</div><div class="act-info"><div class="act-title">${a.text}</div><div class="act-time">${new Date(a.time).toLocaleString('fr-FR',{dateStyle:'short',timeStyle:'short'})}</div></div></div>`).join('')||'<div class="empty" style="padding:1.5rem">Aucune activité</div>';
}
async function sendWorkspaceInvite(){
  const email=document.getElementById('invEmail').value.trim();
  const role=document.getElementById('invRole').value;
  const msg=document.getElementById('invMsg').value.trim();
  if(!email){showA('invAlert','Email requis.','aer');return;}
  if(!/^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(email)){showA('invAlert','Email invalide.','aer');return;}
  if(wsData.members.find(m=>m.email===email)){showA('invAlert','Déjà membre.','aer');return;}
  if(wsData.pending.find(p=>p.email===email)){showA('invAlert','Invitation déjà envoyée.','aer');return;}
  // Build join link with workspace context
  const joinLink=window.location.origin+'?join='+encodeURIComponent(wsData.id)+'&wname='+encodeURIComponent(wsData.name)+'&email='+encodeURIComponent(email)+'&role='+role;
  const r=await API.post('/api/workspace/invite',{email,role,message:msg,workspaceName:wsData.name,workspaceId:wsData.id,joinLink});
  if(r.error){showA('invAlert',r.error,'aer');return;}
  wsData.pending.push({email,role,invitedAt:new Date().toISOString(),joinLink});
  wsData.activity.unshift({text:'Invitation envoyée à '+email,time:new Date().toISOString(),ico:'📨'});
  saveWs();renderWorkspace();
  document.getElementById('invEmail').value='';document.getElementById('invMsg').value='';
  showA('invAlert','✅ Invitation envoyée à '+email+' — lien de rejoindre généré.','aok');
}
function removeWsMember(id){
  const m=wsData.members.find(x=>x.id===id);
  if(!m||!confirm('Retirer '+m.name+' ?'))return;
  wsData.members=wsData.members.filter(x=>x.id!==id);
  wsData.activity.unshift({text:m.name+' retiré de l\'espace',time:new Date().toISOString(),ico:'👤'});
  saveWs();renderWorkspace();
}
function cancelInvite(email){wsData.pending=wsData.pending.filter(p=>p.email!==email);wsData.activity.unshift({text:'Invitation annulée pour '+email,time:new Date().toISOString(),ico:'❌'});saveWs();renderWorkspace();}
function editWorkspaceName(){document.getElementById('modalWsNameInput').value=wsData.name;document.getElementById('modalWsName').style.display='flex';}
function saveWorkspaceName(){const n=document.getElementById('modalWsNameInput').value.trim();if(!n)return;wsData.name=n;wsData.activity.unshift({text:'Espace renommé : '+n,time:new Date().toISOString(),ico:'✏️'});saveWs();renderWorkspace();closeModal('modalWsName');}


// ══════ CRM ═══════════════════════════════════════════════════════════
let crmContacts=[];
const crmStatusLabel={prospect:'🔵 Prospect',lead:'🟡 Lead chaud',client:'🟢 Client',inactif:'⚪ Inactif'};
const crmStatusColor={prospect:'#b2acff',lead:'var(--gold)',client:'var(--a3)',inactif:'var(--muted2)'};
function initCRM(){try{crmContacts=JSON.parse(localStorage.getItem('ph_crm_'+(currentUser?.id||''))||'[]');}catch{crmContacts=[];}renderCRM();}
function addCrmContact(){
  const name=document.getElementById('crmName').value.trim(),company=document.getElementById('crmCompany').value.trim(),email=document.getElementById('crmEmail').value.trim(),phone=document.getElementById('crmPhone').value.trim(),status=document.getElementById('crmStatus').value,value=parseFloat(document.getElementById('crmValue').value)||0;
  if(!name){alert('Nom requis');return;}
  crmContacts.unshift({id:'crm_'+Date.now(),name,company,email,phone,status,value,createdAt:new Date().toISOString(),notes:[]});
  ['crmName','crmCompany','crmEmail','crmPhone','crmValue'].forEach(i=>document.getElementById(i).value='');
  localStorage.setItem('ph_crm_'+(currentUser?.id||''),JSON.stringify(crmContacts));renderCRM();
}
function delCrmContact(id){crmContacts=crmContacts.filter(c=>c.id!==id);localStorage.setItem('ph_crm_'+(currentUser?.id||''),JSON.stringify(crmContacts));renderCRM();}
function renderCRM(){
  if(!document.getElementById('crmList'))return;
  const q=(document.getElementById('crmSearch')?.value||'').toLowerCase();
  const filtered=crmContacts.filter(c=>!q||(c.name+c.company+c.email).toLowerCase().includes(q));
  const prospects=crmContacts.filter(c=>c.status==='prospect').length;
  const leads=crmContacts.filter(c=>c.status==='lead').length;
  const clients=crmContacts.filter(c=>c.status==='client').length;
  const totalValue=crmContacts.filter(c=>c.status==='client').reduce((s,c)=>s+c.value,0);
  document.getElementById('crmStats').innerHTML=`<div class="sc" style="--sac:#b2acff"><div class="lbl">Prospects</div><div class="val">${prospects}</div><div class="sub">contacts</div></div><div class="sc" style="--sac:var(--gold)"><div class="lbl">Leads chauds</div><div class="val">${leads}</div><div class="sub">opportunités</div></div><div class="sc" style="--sac:var(--a3)"><div class="lbl">Clients actifs</div><div class="val">${clients}</div><div class="sub">convertis</div></div><div class="sc" style="--sac:var(--accent)"><div class="lbl">Valeur clients</div><div class="val">${totalValue.toLocaleString('fr-FR')} €</div><div class="sub">CA potentiel</div></div>`;
  // Pipeline
  const stages=['prospect','lead','client'];
  document.getElementById('crmPipeline').innerHTML=stages.map(s=>{const cs=crmContacts.filter(c=>c.status===s);return`<div style="margin-bottom:1rem"><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:.5rem"><span style="font-size:.78rem;font-weight:700;color:${crmStatusColor[s]}">${crmStatusLabel[s]}</span><span style="font-size:.72rem;color:var(--muted2)">${cs.length} contact${cs.length>1?'s':''}</span></div><div style="background:var(--bg3);border-radius:99px;height:6px;overflow:hidden"><div style="width:${crmContacts.length?Math.round(cs.length/crmContacts.length*100):0}%;height:6px;background:${crmStatusColor[s]};border-radius:99px"></div></div></div>`;}).join('');
  const colors=['#6c5ce7','#00cec9','#fdcb6e','#a29bfe','#fd79a8'];
  document.getElementById('crmList').innerHTML=filtered.length?filtered.map((c,i)=>`<div class="user-row"><div class="ua" style="background:${colors[i%colors.length]}">${c.name.charAt(0)}</div><div class="ua-info"><div style="font-weight:600;font-size:.9rem">${c.name}</div><div style="font-size:.73rem;color:var(--muted2)">${c.company||'—'} • ${c.email||'—'}</div></div><span style="font-size:.72rem;font-weight:700;color:${crmStatusColor[c.status]}">${crmStatusLabel[c.status]}</span>${c.value?`<span style="font-size:.82rem;font-weight:700;color:var(--a3);margin-left:.5rem">${c.value.toLocaleString('fr-FR')} €</span>`:''}<button class="btn bd bsm" onclick="delCrmContact('${c.id}')">✕</button></div>`).join(''):'<div class="empty">Aucun contact</div>';
}

// ══════ RH ════════════════════════════════════════════════════════════
let hrEmployees=[],hrLeaves=[];
function initHR(){
  try{hrEmployees=JSON.parse(localStorage.getItem('ph_hr_emp_'+(currentUser?.id||''))||'[]');}catch{hrEmployees=[];}
  try{hrLeaves=JSON.parse(localStorage.getItem('ph_hr_leaves_'+(currentUser?.id||''))||'[]');}catch{hrLeaves=[];}
  renderHR();
}
function addEmployee(){
  const name=document.getElementById('hrName').value.trim(),post=document.getElementById('hrPost').value.trim(),dept=document.getElementById('hrDept').value,salary=parseFloat(document.getElementById('hrSalary').value)||0,start=document.getElementById('hrStart').value,status=document.getElementById('hrStatus').value;
  if(!name){alert('Nom requis');return;}
  hrEmployees.push({id:'hr_'+Date.now(),name,post,dept,salary,start,status});
  ['hrName','hrPost','hrSalary','hrStart'].forEach(i=>document.getElementById(i).value='');
  localStorage.setItem('ph_hr_emp_'+(currentUser?.id||''),JSON.stringify(hrEmployees));renderHR();
}
function delEmployee(id){hrEmployees=hrEmployees.filter(e=>e.id!==id);localStorage.setItem('ph_hr_emp_'+(currentUser?.id||''),JSON.stringify(hrEmployees));renderHR();}
function addLeave(){
  const emp=document.getElementById('leaveEmp').value.trim(),from=document.getElementById('leaveFrom').value,to=document.getElementById('leaveTo').value,type=document.getElementById('leaveType').value;
  if(!emp||!from||!to){alert('Remplis tous les champs');return;}
  const days=Math.round((new Date(to)-new Date(from))/(1000*60*60*24))+1;
  hrLeaves.unshift({id:'lv_'+Date.now(),emp,from,to,type,days,status:'en attente'});
  ['leaveEmp','leaveFrom','leaveTo'].forEach(i=>document.getElementById(i).value='');
  localStorage.setItem('ph_hr_leaves_'+(currentUser?.id||''),JSON.stringify(hrLeaves));renderHR();
}
function approveLeave(id,ok){const idx=hrLeaves.findIndex(l=>l.id===id);if(idx>-1){hrLeaves[idx].status=ok?'approuvé':'refusé';localStorage.setItem('ph_hr_leaves_'+(currentUser?.id||''),JSON.stringify(hrLeaves));renderHR();}}
function renderHR(){
  if(!document.getElementById('hrList'))return;
  const totalSalary=hrEmployees.reduce((s,e)=>s+e.salary,0);
  const actifs=hrEmployees.filter(e=>e.status==='actif').length;
  const enConge=hrEmployees.filter(e=>e.status==='conge').length;
  document.getElementById('hrStats').innerHTML=`<div class="sc" style="--sac:var(--accent)"><div class="lbl">Employés</div><div class="val">${hrEmployees.length}</div><div class="sub">${actifs} actifs</div></div><div class="sc" style="--sac:var(--gold)"><div class="lbl">En congé</div><div class="val">${enConge}</div><div class="sub">aujourd'hui</div></div><div class="sc" style="--sac:#ff7070"><div class="lbl">Masse salariale</div><div class="val">${totalSalary.toLocaleString('fr-FR')} €</div><div class="sub">brut / mois</div></div><div class="sc" style="--sac:var(--a3)"><div class="lbl">Demandes congés</div><div class="val">${hrLeaves.filter(l=>l.status==='en attente').length}</div><div class="sub">en attente</div></div>`;
  const statusColors={actif:'var(--a3)',essai:'var(--gold)',conge:'#b2acff',absent:'#ff7070'};
  const colors=['#6c5ce7','#00cec9','#fdcb6e','#a29bfe','#fd79a8'];
  document.getElementById('hrList').innerHTML=hrEmployees.length?hrEmployees.map((e,i)=>`<div class="user-row"><div class="ua" style="background:${colors[i%colors.length]}">${e.name.charAt(0)}</div><div class="ua-info"><div style="font-weight:600;font-size:.9rem">${e.name}</div><div style="font-size:.73rem;color:var(--muted2)">${e.post} — ${e.dept}</div></div><span style="font-size:.75rem;font-weight:700;color:${statusColors[e.status]||'var(--muted2)'}">${e.status}</span><span style="font-size:.82rem;color:var(--muted2);margin-left:.5rem">${e.salary?e.salary.toLocaleString('fr-FR')+' €':''}</span><button class="btn bd bsm" onclick="delEmployee('${e.id}')">✕</button></div>`).join(''):'<div class="empty">Aucun employé — ajoutez votre équipe</div>';
  document.getElementById('leaveList').innerHTML=hrLeaves.slice(0,5).map(l=>`<div class="user-row"><div class="ua-info"><div style="font-size:.875rem;font-weight:600">${l.emp}</div><div style="font-size:.73rem;color:var(--muted2)">${l.type} • ${new Date(l.from).toLocaleDateString('fr-FR')} → ${new Date(l.to).toLocaleDateString('fr-FR')} (${l.days}j)</div></div><span class="pill ${l.status==='approuvé'?'pg':l.status==='refusé'?'pr2':'py'}">${l.status}</span>${l.status==='en attente'?`<button class="btn bg2 bsm" onclick="approveLeave('${l.id}',true)">✓</button><button class="btn bd bsm" onclick="approveLeave('${l.id}',false)">✕</button>`:''}</div>`).join('')||'<div class="empty" style="padding:1rem">Aucune demande</div>';
}

// ══════ REPORTING ═════════════════════════════════════════════════════
let chRep1,chRep2;
// ══════ REPORTING FINANCIER ══════════════════════════════════════
let chRep1,chRep2,chRep3,chBudEnt1,chBudEnt2;
let reportPeriod='month';

function setReportPeriod(p,btn){
  reportPeriod=p;
  document.querySelectorAll('.rptab').forEach(b=>b.classList.remove('active'));
  if(btn)btn.classList.add('active');
  renderReporting();
}

function getFilteredTxs(){
  const uid=currentUser?.id||'';
  const txs=JSON.parse(localStorage.getItem('ph_budget_'+uid)||'[]');
  const now=new Date();
  if(reportPeriod==='month') return txs.filter(t=>{try{const d=new Date(t.date?.split('/').reverse().join('-')||Date.now());return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();}catch{return true;}});
  if(reportPeriod==='quarter'){const q=Math.floor(now.getMonth()/3);return txs.filter(t=>{try{const d=new Date(t.date?.split('/').reverse().join('-')||Date.now());return Math.floor(d.getMonth()/3)===q&&d.getFullYear()===now.getFullYear();}catch{return true;}});}
  if(reportPeriod==='year') return txs.filter(t=>{try{const d=new Date(t.date?.split('/').reverse().join('-')||Date.now());return d.getFullYear()===now.getFullYear();}catch{return true;}});
  return txs;
}

function initReporting(){renderReporting();}

function renderReporting(){
  if(!document.getElementById('reportStats'))return;
  const txs=getFilteredTxs();
  const allTxs=JSON.parse(localStorage.getItem('ph_budget_'+(currentUser?.id||''))||'[]');
  const rev=txs.filter(t=>t.type==='revenu').reduce((s,t)=>s+t.a,0);
  const dep=txs.filter(t=>t.type==='depense').reduce((s,t)=>s+t.a,0);
  const sal=hrEmployees.reduce((s,e)=>s+e.salary,0);
  const ebit=rev-dep;
  const margin=rev>0?Math.round(ebit/rev*100):0;
  const prevRev=allTxs.filter(t=>t.type==='revenu').reduce((s,t)=>s+t.a,0);
  const trend=prevRev>0?Math.round((rev-prevRev/12)/prevRev*1200):0;
  const periodLabels={month:'Ce mois-ci',quarter:'Ce trimestre',year:'Cette année',all:'Toutes périodes'};
  document.getElementById('reportPeriodLabel').textContent=periodLabels[reportPeriod]||'';
  
  const mkTrend=(v)=>v>0?`<span class="kpi-trend kpi-up">▲ ${v}%</span>`:v<0?`<span class="kpi-trend kpi-down">▼ ${Math.abs(v)}%</span>`:`<span class="kpi-trend kpi-flat">→ stable</span>`;
  document.getElementById('reportStats').innerHTML=`
    <div class="sc" style="--sac:var(--a3)"><div class="lbl">Chiffre d'affaires</div><div class="val">${rev.toLocaleString('fr-FR')} €</div><div class="sub">${mkTrend(trend)} vs mois préc.</div></div>
    <div class="sc" style="--sac:#ff7070"><div class="lbl">Charges totales</div><div class="val">${dep.toLocaleString('fr-FR')} €</div><div class="sub">${txs.filter(t=>t.type==='depense').length} transactions</div></div>
    <div class="sc" style="--sac:var(--gold)"><div class="lbl">Résultat net</div><div class="val" style="color:${ebit>=0?'var(--a3)':'#ff7070'}">${ebit.toLocaleString('fr-FR')} €</div><div class="sub">EBIT simplifié</div></div>
    <div class="sc" style="--sac:var(--pp2)"><div class="lbl">Marge nette</div><div class="val">${margin}%</div><div class="sub">${margin>20?'✅ Excellent':margin>10?'🟡 Correct':rev>0?'🔴 Faible':'—'}</div></div>`;

  // Analysis
  document.getElementById('reportAnalysis').innerHTML=`<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1rem">${[
    {label:'Rentabilité',value:margin+'%',status:margin>20?'✅ Excellent':margin>10?'🟡 Correct':rev>0?'🔴 À améliorer':'—'},
    {label:'Charges / CA',value:rev>0?Math.round(dep/rev*100)+'%':'—',status:rev>0&&dep/rev<0.6?'✅ Maîtrisé':rev>0?'⚠️ Élevé':'—'},
    {label:'Coût salarial',value:sal?sal.toLocaleString('fr-FR')+' €/mois':'—',status:rev>0&&sal?Math.round(sal/rev*1200)+'% du CA annuel':'ℹ️ Aucun employé'},
    {label:'Clients actifs',value:crmContacts.filter(c=>c.status==='client').length+'',status:'Pipeline : '+crmContacts.filter(c=>c.status==='lead').length+' leads'},
    {label:'Panier moyen',value:txs.filter(t=>t.type==='revenu').length>0?(rev/txs.filter(t=>t.type==='revenu').length).toFixed(0)+' €':'—',status:'/ transaction revenu'},
    {label:'Point mort',value:dep>0&&margin>0?Math.round(dep/(margin/100)).toLocaleString('fr-FR')+' €':'—',status:'CA nécessaire équilibre'}
  ].map(i=>`<div class="card" style="margin:0;text-align:center"><div style="font-size:.72rem;color:var(--muted2);margin-bottom:.35rem">${i.label}</div><div style="font-size:1.4rem;font-weight:800;font-family:'Syne',sans-serif">${i.value}</div><div style="font-size:.72rem;margin-top:.35rem;color:var(--muted2)">${i.status}</div></div>`).join('')}</div>`;

  // Top clients
  const topEl=document.getElementById('reportTopClients');
  if(topEl){
    const clients=crmContacts.filter(c=>c.value>0).sort((a,b)=>b.value-a.value).slice(0,5);
    const maxVal=clients[0]?.value||1;
    topEl.innerHTML=clients.length?clients.map(c=>`<div class="budget-item"><div style="width:130px;font-size:.83rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.name}</div><div class="budget-bar-wrap"><div class="budget-bar" style="width:${Math.round(c.value/maxVal*100)}%;background:var(--a3)"></div></div><div style="width:90px;text-align:right;font-size:.82rem;font-weight:700;color:var(--a3)">${c.value.toLocaleString('fr-FR')} €</div><span style="width:70px;text-align:right;font-size:.7rem;color:var(--muted2)">${c.company||''}</span></div>`).join(''):'<div class="empty" style="padding:1.5rem">Ajoutez des clients avec une valeur dans le CRM</div>';
  }

  // Forecast
  const forecastEl=document.getElementById('reportForecast');
  if(forecastEl&&txs.length>2){
    const revs=txs.filter(t=>t.type==='revenu');
    const avgRev=revs.length>0?rev/revs.length:0;
    const growth=trend/100;
    const months3=['Mois +1','Mois +2','Mois +3'];
    const forecasts=months3.map((_,i)=>Math.round(avgRev*revs.length*(1+growth)*(i+1)/3));
    forecastEl.innerHTML=forecasts.map((f,i)=>`<div class="forecast-line"><span style="font-size:.83rem;color:var(--muted2)">${months3[i]}</span><div style="flex:1;margin:0 1rem;background:var(--bg3);border-radius:99px;height:6px"><div style="width:${Math.min(100,Math.round(f/Math.max(...forecasts)*100))}%;height:6px;background:linear-gradient(90deg,var(--accent),var(--a3));border-radius:99px"></div></div><span style="font-weight:700;color:var(--a3)">${f.toLocaleString('fr-FR')} €</span></div>`).join('');
  } else if(forecastEl){
    forecastEl.innerHTML='<div class="empty" style="padding:1.5rem">Ajoutez des transactions pour voir les prévisions</div>';
  }

  const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
  setTimeout(()=>{
    if(chRep1)chRep1.destroy();
    const el1=document.getElementById('chReport1');if(!el1)return;
    // Build real monthly data from transactions
    const monthly=months.map((_,mi)=>{
      const mTxs=allTxs.filter(t=>{try{const d=new Date(t.date?.split('/').reverse().join('-')||'');return d.getMonth()===mi;}catch{return false;}});
      return{rev:mTxs.filter(t=>t.type==='revenu').reduce((s,t)=>s+t.a,0),dep:mTxs.filter(t=>t.type==='depense').reduce((s,t)=>s+t.a,0)};
    });
    const hasReal=monthly.some(m=>m.rev>0||m.dep>0);
    const revData=hasReal?monthly.map(m=>m.rev):months.map(()=>Math.round((rev||5000)/12*(0.6+Math.random()*0.8)));
    const depData=hasReal?monthly.map(m=>m.dep):months.map(()=>Math.round((dep||3000)/12*(0.6+Math.random()*0.8)));
    document.getElementById('reportChartTitle').textContent=hasReal?'(données réelles)':'(simulation)';
    chRep1=new Chart(el1.getContext('2d'),{type:'bar',data:{labels:months,datasets:[{label:'CA',data:revData,backgroundColor:'rgba(0,206,201,0.55)',borderColor:'#00cec9',borderWidth:1,borderRadius:4},{label:'Charges',data:depData,backgroundColor:'rgba(255,70,102,0.4)',borderColor:'#ff4466',borderWidth:1,borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a'}}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a',callback:v=>v.toLocaleString('fr-FR')+'€'},grid:{color:'rgba(255,255,255,0.04)'}}}}});
    
    if(chRep2)chRep2.destroy();
    const el2=document.getElementById('chReport2');if(!el2)return;
    const cats={};txs.filter(t=>t.type==='depense').forEach(t=>{cats[t.cat]=(cats[t.cat]||0)+t.a;});
    if(!Object.keys(cats).length){cats['Aucune charge']=1;}
    chRep2=new Chart(el2.getContext('2d'),{type:'doughnut',data:{labels:Object.keys(cats),datasets:[{data:Object.values(cats),backgroundColor:['#6c5ce7','#fd79a8','#00cec9','#fdcb6e','#a29bfe','#ff7070','#0984e3'],borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:'#7a7a9a',font:{size:10}}}}}});

    if(chRep3)chRep3.destroy();
    const el3=document.getElementById('chReport3');if(!el3)return;
    let cumul=0;const tresoData=revData.map((r,i)=>{cumul+=r-depData[i];return Math.round(cumul);});
    chRep3=new Chart(el3.getContext('2d'),{type:'line',data:{labels:months,datasets:[{label:'Trésorerie cumulée',data:tresoData,borderColor:tresoData[tresoData.length-1]>=0?'#00cec9':'#ff4466',backgroundColor:tresoData[tresoData.length-1]>=0?'rgba(0,206,201,0.08)':'rgba(255,70,102,0.08)',tension:0.4,fill:true,pointRadius:3}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a'}}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a',callback:v=>v.toLocaleString('fr-FR')+'€'},grid:{color:'rgba(255,255,255,0.04)'}}}}});
  },100);
}

function exportFEC(){
  const uid=currentUser?.id||'';
  const txs=JSON.parse(localStorage.getItem('ph_budget_'+uid)||'[]');
  if(!txs.length){alert('Aucune transaction à exporter.\nUtilisez le bouton "Charger données démo" pour tester.');return;}
  const header='JournalCode|JournalLib|EcritureNum|EcritureDate|CompteNum|CompteLib|PieceRef|EcheanceDate|Debit|Credit\n';
  const lines=txs.map((t,i)=>{
    const code=t.type==='revenu'?'VT':'AC';
    const compte=t.type==='revenu'?'706000':'601000';
    const lib=t.type==='revenu'?'Produits des ventes':'Achats et charges externes';
    const today=new Date().toISOString().split('T')[0].replace(/-/g,'');
    return`${code}|${lib}|${String(i+1).padStart(6,'0')}|${today}|${compte}|${t.cat||'Divers'}|FAC${String(i+1).padStart(5,'0')}|${today}|${t.type==='depense'?t.a.toFixed(2):'0.00'}|${t.type==='revenu'?t.a.toFixed(2):'0.00'}`;
  }).join('\n');
  const blob=new Blob([header+lines],{type:'text/plain;charset=utf-8'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='FEC_ProHub_'+new Date().getFullYear()+'.txt';a.click();
}

function exportReportExcel(){
  const uid=currentUser?.id||'';
  const txs=JSON.parse(localStorage.getItem('ph_budget_'+uid)||'[]');
  if(!txs.length){alert('Aucune donnée.\nChargez des données démo d'abord.');return;}
  if(typeof XLSX==='undefined'){alert('Bibliothèque Excel non chargée. Rechargez la page.');return;}
  const wb=XLSX.utils.book_new();
  // Sheet 1: transactions
  const txData=[['Description','Catégorie','Type','Montant (€)','Date'],...txs.map(t=>[t.d||'—',t.cat||'—',t.type,t.a,(t.date||'—')])];
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(txData),'Transactions');
  // Sheet 2: summary
  const rev=txs.filter(t=>t.type==='revenu').reduce((s,t)=>s+t.a,0);
  const dep=txs.filter(t=>t.type==='depense').reduce((s,t)=>s+t.a,0);
  const sumData=[['Indicateur','Valeur'],['Chiffre d'affaires',rev],['Charges totales',dep],['Résultat net',rev-dep],['Marge nette (%)',rev>0?Math.round((rev-dep)/rev*100):0],['Nombre transactions',txs.length]];
  XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(sumData),'Résumé');
  // Sheet 3: CRM
  if(crmContacts.length){
    const crmData=[['Nom','Entreprise','Email','Téléphone','Statut','Valeur (€)'],...crmContacts.map(c=>[c.name,c.company||'',c.email||'',c.phone||'',c.status,c.value||0])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(crmData),'CRM Clients');
  }
  // Sheet 4: HR
  if(hrEmployees.length){
    const hrData=[['Nom','Poste','Département','Salaire brut (€)','Statut','Date entrée'],...hrEmployees.map(e=>[e.name,e.post||'',e.dept||'',e.salary||0,e.status||'',e.start||''])];
    XLSX.utils.book_append_sheet(wb,XLSX.utils.aoa_to_sheet(hrData),'RH Employés');
  }
  XLSX.writeFile(wb,'ProHub_Rapport_'+new Date().getFullYear()+'.xlsx');
}

function exportPayroll(){
  if(typeof XLSX==='undefined'){alert('Bibliothèque Excel non chargée.');return;}
  if(!hrEmployees.length){alert('Aucun employé.\nAjoutez des employés dans RH & Paie.');return;}
  const wb=XLSX.utils.book_new();
  const data=[
    ['Nom','Poste','Département','Salaire brut (€)','Charges patronales (~45%)','Coût total employeur','Statut'],
    ...hrEmployees.map(e=>{
      const brut=e.salary||0;
      const charges=Math.round(brut*0.45);
      return[e.name,e.post||'',e.dept||'',brut,charges,brut+charges,e.status||'actif'];
    }),
    ['','','','TOTAL',
      hrEmployees.reduce((s,e)=>s+Math.round((e.salary||0)*0.45),0),
      hrEmployees.reduce((s,e)=>s+(e.salary||0)+Math.round((e.salary||0)*0.45),0),'']
  ];
  const ws=XLSX.utils.aoa_to_sheet(data);
  XLSX.utils.book_append_sheet(wb,ws,'Masse salariale');
  XLSX.writeFile(wb,'ProHub_Paie_'+new Date().toLocaleDateString('fr-FR').replace(/\//g,'-')+'.xlsx');
}

