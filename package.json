// TVA
function calcTVA(){const ca=parseFloat(document.getElementById('tvaca')?.value||50000),taux=parseFloat(document.getElementById('tvataux')?.value||20),statut=document.getElementById('tvastatut')?.value||'ae_bic',dep=parseFloat(document.getElementById('tvadep')?.value||5000);const tvaCollectee=ca*taux/100,tvaDeduite=dep*taux/100,tvaNet=tvaCollectee-tvaDeduite;const charges={ae_bic:ca*0.121,ae_bnc:ca*0.219,sasu:ca*0.45}[statut]||0;const net=ca-charges-(statut!=='ae_bic'&&statut!=='ae_bnc'?tvaNet:0);const el=document.getElementById('tvar');if(!el)return;el.innerHTML=Rw('CA HT',ca.toLocaleString('fr-FR')+' €')+Rw('TVA collectée ('+taux+'%)',tvaCollectee.toFixed(2)+' €','#ff7070')+Rw('TVA déductible sur achats',tvaDeduite.toFixed(2)+' €','var(--a3)')+Rw('TVA à reverser',Math.max(0,tvaNet).toFixed(2)+' €','#ff7070')+Rw('Charges sociales estimées',charges.toFixed(0)+' €','var(--muted2)')+Rw('Revenu net estimé',net.toFixed(0)+' €',net>2000?'var(--a3)':'var(--gold)');}

// CONTRATS
function genContrat(){const n=document.getElementById('ctn').value||'Prestataire',c=document.getElementById('ctc').value||'Client',type=document.getElementById('cttype').value,mnt=document.getElementById('ctmnt').value||'0',deb=document.getElementById('ctdeb').value,fin=document.getElementById('ctfin').value,acc=document.getElementById('ctacc').value||30,desc=document.getElementById('ctdesc').value||'Prestation à définir';const w=window.open('','_blank');w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Contrat</title><style>body{font-family:Arial,sans-serif;padding:50px;max-width:750px;margin:auto;color:#111;line-height:1.7}h1{font-size:1.4rem;border-bottom:2px solid #6c5ce7;padding-bottom:10px;color:#6c5ce7}h2{font-size:1rem;margin-top:1.5rem;margin-bottom:.5rem}p{margin-bottom:.75rem}.parties{display:grid;grid-template-columns:1fr 1fr;gap:20px;background:#f9f9f9;padding:20px;border-radius:8px;margin:1rem 0}.sign{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:3rem}.sign-box{border-top:1px solid #333;padding-top:10px;font-size:.85rem}button{margin-top:1.5rem;padding:10px 24px;background:#6c5ce7;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:1rem}@media print{button{display:none}}</style></head><body><h1>CONTRAT DE PRESTATION — ${type.toUpperCase()}</h1><div class="parties"><div><strong>LE PRESTATAIRE</strong><br>${n}</div><div><strong>LE CLIENT</strong><br>${c}</div></div><h2>Article 1 — Objet du contrat</h2><p>Le présent contrat a pour objet la réalisation d'une prestation de <strong>${type}</strong> par ${n} pour le compte de ${c}.</p><p>${desc}</p><h2>Article 2 — Durée</h2><p>La prestation débute le <strong>${deb||'—'}</strong> et se termine le <strong>${fin||'—'}</strong>.</p><h2>Article 3 — Rémunération</h2><p>Le montant total de la prestation est fixé à <strong>${mnt} € HT</strong>.</p><p>Un acompte de <strong>${acc}%</strong> soit <strong>${(parseFloat(mnt)*acc/100).toFixed(2)} €</strong> est dû à la signature. Le solde est dû à la livraison.</p><h2>Article 4 — Propriété intellectuelle</h2><p>Après règlement complet, le client devient propriétaire des livrables. Le prestataire conserve le droit de mentionner cette réalisation dans son portfolio.</p><h2>Article 5 — Confidentialité</h2><p>Les parties s'engagent à ne pas divulguer les informations confidentielles échangées dans le cadre de ce contrat.</p><h2>Article 6 — Litiges</h2><p>En cas de litige, les parties s'engagent à rechercher une solution amiable avant tout recours judiciaire.</p><div class="sign"><div class="sign-box"><strong>Le Prestataire</strong><br>${n}<br><br>Date & Signature :</div><div class="sign-box"><strong>Le Client</strong><br>${c}<br><br>Date & Signature :</div></div><button onclick="window.print()">📄 Imprimer / Exporter PDF</button></body></html>`);w.document.close();}

// ÉQUIPE
let teamMembers=[];
function initTeam(){try{teamMembers=JSON.parse(localStorage.getItem('ph_team_'+(currentUser?.id||''))||'[]');}catch{teamMembers=[];}if(!teamMembers.length)teamMembers=[{id:1,name:currentUser?.name||'Propriétaire',email:currentUser?.email||'—',role:'Manager',status:'actif'}];renderTeam();}
function addTeamMember(){const n=document.getElementById('tmName').value.trim(),e=document.getElementById('tmEmail').value.trim(),r=document.getElementById('tmRole').value;if(!n||!e){alert('Nom et e-mail requis');return;}teamMembers.push({id:Date.now(),name:n,email:e,role:r,status:'invité'});['tmName','tmEmail'].forEach(i=>document.getElementById(i).value='');localStorage.setItem('ph_team_'+(currentUser?.id||''),JSON.stringify(teamMembers));renderTeam();}
function removeTeamMember(id){teamMembers=teamMembers.filter(m=>m.id!==id);localStorage.setItem('ph_team_'+(currentUser?.id||''),JSON.stringify(teamMembers));renderTeam();}
function renderTeam(){document.getElementById('teamCount').textContent=teamMembers.length+' membre'+(teamMembers.length>1?'s':'');const colors=['#6c5ce7','#00cec9','#fdcb6e','#a29bfe','#fd79a8'];document.getElementById('teamList').innerHTML=teamMembers.map((m,i)=>`<div class="user-row"><div class="ua" style="background:${colors[i%colors.length]}">${m.name.charAt(0).toUpperCase()}</div><div class="ua-info"><div style="font-size:.875rem;font-weight:600">${m.name}</div><div style="font-size:.73rem;color:var(--muted2)">${m.email}</div></div><span class="pill pb" style="margin-right:.5rem">${m.role}</span><span class="pill ${m.status==='actif'?'pg':'py'}">${m.status}</span>${i>0?`<button class="btn bd bsm" onclick="removeTeamMember(${m.id})" style="margin-left:.5rem">✕</button>`:''}</div>`).join('');}

// EMAILS EN MASSE
let emailCampagnes=[];
async function envoyerEmails(){const obj=document.getElementById('emobj').value.trim(),exp=document.getElementById('emexp').value.trim(),dest=document.getElementById('emdest').value.trim(),content=document.getElementById('emcontent').value.trim();if(!obj||!dest||!content){showA('emAlert','Remplis tous les champs obligatoires.','error');return;}const recipients=dest.split('\n').map(e=>e.trim()).filter(e=>e);if(!recipients.length){showA('emAlert','Aucun destinataire valide.','error');return;}document.getElementById('emstatus').textContent='⏳ Envoi en cours...';document.getElementById('emBtn').disabled=true;const r=await API.post('/api/emails/send-campaign',{subject:obj,sender:exp,recipients,content});document.getElementById('emBtn').disabled=false;if(r.error){document.getElementById('emstatus').textContent='';showA('emAlert',r.error,'error');return;}emailCampagnes.unshift({obj,dests:r.sent,date:new Date().toLocaleDateString('fr-FR'),status:'Envoyé',failed:r.failed});document.getElementById('emstatus').textContent='✅ Envoyé à '+r.sent+' destinataires'+(r.failed?' ('+r.failed+' échec)':'');renderEmailHist();}
function renderEmailHist(){document.getElementById('emhist').innerHTML=emailCampagnes.length?emailCampagnes.map(c=>`<div class="user-row"><div style="flex:1"><div style="font-weight:600;font-size:.9rem">${c.obj}</div><div style="font-size:.75rem;color:var(--muted2)">${c.date} • ${c.dests} envoyés${c.failed?' • <span style="color:#ff7070">'+c.failed+' échecs</span>':''}</div></div><span class="pill pg">${c.status}</span></div>`).join(''):'<div class="empty">Aucune campagne envoyée</div>';}

// AGENDA
let agEvents=[];
function initAgenda(){try{agEvents=JSON.parse(localStorage.getItem('ph_agenda_'+(currentUser?.id||''))||'[]');}catch{agEvents=[];}renderAgenda();}
function addEvent(){const t=document.getElementById('agTitre').value.trim(),d=document.getElementById('agDate').value,type=document.getElementById('agType').value;if(!t||!d){alert('Titre et date requis');return;}agEvents.push({id:Date.now(),titre:t,date:d,type});agEvents.sort((a,b)=>new Date(a.date)-new Date(b.date));['agTitre','agDate'].forEach(id=>document.getElementById(id).value='');localStorage.setItem('ph_agenda_'+(currentUser?.id||''),JSON.stringify(agEvents));renderAgenda();}
function delEvent(id){agEvents=agEvents.filter(e=>e.id!==id);localStorage.setItem('ph_agenda_'+(currentUser?.id||''),JSON.stringify(agEvents));renderAgenda();}
function renderAgenda(){const now=new Date(),typeIco={rdv:'📅',deadline:'⚠️',rappel:'🔔',perso:'👤'};const upcoming=agEvents.filter(e=>new Date(e.date)>=now).slice(0,5);const thisMonth=agEvents.filter(e=>{const d=new Date(e.date);return d.getMonth()===now.getMonth()&&d.getFullYear()===now.getFullYear();});document.getElementById('agList').innerHTML=upcoming.length?upcoming.map(e=>`<div class="user-row"><span style="font-size:1.3rem">${typeIco[e.type]||'📅'}</span><div class="ua-info"><div style="font-weight:600;font-size:.875rem">${e.titre}</div><div style="font-size:.75rem;color:var(--muted2)">${new Date(e.date).toLocaleString('fr-FR',{dateStyle:'medium',timeStyle:'short'})}</div></div><button class="btn bd bsm" onclick="delEvent(${e.id})">✕</button></div>`).join(''):'<div class="empty" style="padding:1.5rem">Aucun événement à venir</div>';document.getElementById('agMonth').innerHTML=thisMonth.length?thisMonth.map(e=>`<div class="user-row"><span style="font-size:1.2rem">${typeIco[e.type]||'📅'}</span><div class="ua-info"><div style="font-weight:600;font-size:.875rem">${e.titre}</div><div style="font-size:.75rem;color:var(--muted2)">${new Date(e.date).toLocaleString('fr-FR',{dateStyle:'medium',timeStyle:'short'})}</div></div></div>`).join(''):'<div class="empty" style="padding:1.5rem">Aucun événement ce mois</div>';}

// CHATBOT
// NOTES RAPIDES
let notesList=[];
const noteCat={idee:{ico:'💡',cls:'mb-b'},tache:{ico:'✅',cls:'mb-g'},info:{ico:'ℹ️',cls:'mb-o'},urgent:{ico:'🔥',cls:'mb-p'}};
function initNotes(){try{notesList=JSON.parse(localStorage.getItem('ph_notes_'+(currentUser?.id||''))||'[]');}catch{notesList=[];}renderNotes();}
function addNote(){const t=document.getElementById('noteTitre').value.trim(),c=document.getElementById('noteContent').value.trim(),cat=document.getElementById('noteCat').value;if(!t){alert('Titre requis');return;}notesList.unshift({id:Date.now(),titre:t,content:c,cat,date:new Date().toLocaleDateString('fr-FR')});document.getElementById('noteTitre').value='';document.getElementById('noteContent').value='';localStorage.setItem('ph_notes_'+(currentUser?.id||''),JSON.stringify(notesList));renderNotes();}
function delNote(id){notesList=notesList.filter(n=>n.id!==id);localStorage.setItem('ph_notes_'+(currentUser?.id||''),JSON.stringify(notesList));renderNotes();}
function renderNotes(){const el=document.getElementById('notesList');if(!el)return;el.innerHTML=notesList.length?notesList.map(n=>`<div class="mc" style="position:relative"><button class="btn bd bsm" onclick="delNote(${n.id})" style="position:absolute;top:.75rem;right:.75rem">✕</button><span style="font-size:1.5rem">${noteCat[n.cat]?.ico||'📒'}</span><div class="mc-n" style="margin-top:.5rem">${n.titre}</div><div class="mc-d" style="margin-top:.35rem;white-space:pre-wrap">${n.content||'—'}</div><span class="mb-badge ${noteCat[n.cat]?.cls||'mb-b'}" style="margin-top:.75rem">${n.date}</span></div>`).join(''):'<div class="empty" style="padding:2rem;grid-column:1/-1">Aucune note</div>';}

// OBJECTIFS & KPIs
let kpiList=[];
function initKpis(){try{kpiList=JSON.parse(localStorage.getItem('ph_kpis_'+(currentUser?.id||''))||'[]');}catch{kpiList=[];}renderKpis();}
function addKpi(){const n=document.getElementById('kpiNom').value.trim(),c=parseFloat(document.getElementById('kpiCible').value),a=parseFloat(document.getElementById('kpiActuel').value),u=document.getElementById('kpiUnit').value.trim();if(!n||isNaN(c)){alert('Nom et cible requis');return;}kpiList.push({id:Date.now(),nom:n,cible:c,actuel:isNaN(a)?0:a,unit:u||''});['kpiNom','kpiCible','kpiActuel','kpiUnit'].forEach(i=>document.getElementById(i).value='');localStorage.setItem('ph_kpis_'+(currentUser?.id||''),JSON.stringify(kpiList));renderKpis();}
function updateKpi(id,val){const idx=kpiList.findIndex(k=>k.id===id);if(idx>-1){kpiList[idx].actuel=parseFloat(val)||0;localStorage.setItem('ph_kpis_'+(currentUser?.id||''),JSON.stringify(kpiList));renderKpis();}}
function delKpi(id){kpiList=kpiList.filter(k=>k.id!==id);localStorage.setItem('ph_kpis_'+(currentUser?.id||''),JSON.stringify(kpiList));renderKpis();}
function renderKpis(){const el=document.getElementById('kpiList');if(!el)return;el.innerHTML=kpiList.length?kpiList.map(k=>{const pct=Math.min(100,Math.round((k.actuel/k.cible)*100));const col=pct>=100?'var(--a3)':pct>=60?'var(--gold)':'#ff7070';return`<div class="card" style="margin-bottom:.75rem"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:.75rem"><div style="font-weight:700">${k.nom}</div><div style="display:flex;gap:.5rem;align-items:center"><span style="font-size:.85rem;color:${col};font-weight:700">${pct}%</span><button class="btn bd bsm" onclick="delKpi(${k.id})">✕</button></div></div><div style="background:var(--bg3);border-radius:99px;height:8px;margin-bottom:.75rem"><div style="background:${col};height:8px;border-radius:99px;width:${pct}%;transition:width .4s"></div></div><div style="display:flex;justify-content:space-between;align-items:center;font-size:.8rem;color:var(--muted2)"><span>Actuel : <input type="number" value="${k.actuel}" onchange="updateKpi(${k.id},this.value)" style="width:80px;background:var(--bg3);border:1px solid var(--border2);color:var(--text);border-radius:6px;padding:2px 6px;font-size:.8rem"> ${k.unit}</span><span>Cible : ${k.cible} ${k.unit}</span></div></div>`}).join(''):'<div class="card"><div class="empty">Aucun objectif défini</div></div>';}

// FACTURES RÉCURRENTES
let recList2=[];
async function initRecurrents(){try{const r=await API.get('/api/recurrents');recList2=Array.isArray(r)?r:[];}catch{recList2=[];}renderRecurrents();}
async function addRecurrent(){const c=document.getElementById('recClient').value.trim(),m=parseFloat(document.getElementById('recMontant').value),f=document.getElementById('recFreq').value,d=document.getElementById('recDate').value,desc=document.getElementById('recDesc').value.trim();if(!c||isNaN(m)){alert('Client et montant requis');return;}const r=await API.post('/api/recurrents',{client:c,montant:m,freq:f,prochainEnvoi:d,desc,actif:true});if(r.rec)recList2.unshift(r.rec);['recClient','recMontant','recDate','recDesc'].forEach(i=>document.getElementById(i).value='');renderRecurrents();}
async function toggleRec(id){const rec=recList2.find(r=>r.id===id);if(!rec)return;await API.patch('/api/recurrents/'+id,{actif:!rec.actif});rec.actif=!rec.actif;renderRecurrents();}
async function delRec(id){await API.del('/api/recurrents/'+id);recList2=recList2.filter(r=>r.id!==id);renderRecurrents();}
function renderRecurrents(){const el=document.getElementById('recList');if(!el)return;const freqLabel={mensuel:'Mensuel',trimestriel:'Trimestriel',annuel:'Annuel'};const freqMult={mensuel:1,trimestriel:1/3,annuel:1/12};el.innerHTML=recList2.length?recList2.map(r=>`<div class="card" style="margin-bottom:.75rem;opacity:${r.actif?1:.5}"><div style="display:flex;justify-content:space-between;align-items:center"><div><div style="font-weight:700;font-size:.95rem">${r.client}</div><div style="font-size:.78rem;color:var(--muted2);margin-top:3px">${r.desc||'—'} • ${freqLabel[r.freq]}</div>${r.prochainEnvoi?`<div style="font-size:.72rem;color:var(--gold);margin-top:3px">Prochain envoi : ${new Date(r.prochainEnvoi).toLocaleDateString('fr-FR')}</div>`:''}</div><div style="display:flex;align-items:center;gap:.5rem"><span style="font-size:1.1rem;font-weight:800;color:var(--a3)">${r.montant} €</span><button class="btn bsm ${r.actif?'bg2':'bd'}" onclick="toggleRec('${r.id}')">${r.actif?'✓ Actif':'En pause'}</button><button class="btn bd bsm" onclick="delRec('${r.id}')">🗑</button></div></div></div>`).join(''):'<div class="card"><div class="empty">Aucune facture récurrente</div></div>';const actifs=recList2.filter(r=>r.actif);const mrr=actifs.reduce((s,r)=>s+r.montant*(freqMult[r.freq]||1),0);const statsEl=document.getElementById('recStats');if(statsEl)statsEl.innerHTML=`<div class="sc" style="--sac:var(--a3)"><div class="lbl">MRR estimé</div><div class="val">${Math.round(mrr)} €</div><div class="sub">Revenus mensuels</div></div><div class="sc" style="--sac:var(--gold)"><div class="lbl">ARR estimé</div><div class="val">${Math.round(mrr*12)} €</div><div class="sub">Revenus annuels</div></div><div class="sc" style="--sac:var(--pp2)"><div class="lbl">Clients actifs</div><div class="val">${actifs.length}</div><div class="sub">contrats en cours</div></div>`;}

