function exportBilan(){
  const uid=currentUser?.id||'';
  const txs=JSON.parse(localStorage.getItem('ph_budget_'+uid)||'[]');
  const rev=txs.filter(t=>t.type==='revenu').reduce((s,t)=>s+t.a,0);
  const dep=txs.filter(t=>t.type==='depense').reduce((s,t)=>s+t.a,0);
  const sal=hrEmployees.reduce((s,e)=>s+(e.salary||0),0);
  const charges=dep;const net=rev-dep;const margin=rev>0?Math.round(net/rev*100):0;
  const cats={};txs.filter(t=>t.type==='depense').forEach(t=>{cats[t.cat||'Autre']=(cats[t.cat||'Autre']||0)+t.a;});
  const w=window.open('','_blank');
  w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Bilan ProHub ${new Date().getFullYear()}</title><style>*{box-sizing:border-box}body{font-family:Arial,sans-serif;padding:40px;color:#111;max-width:750px;margin:auto;line-height:1.6}h1{color:#6c5ce7;border-bottom:3px solid #6c5ce7;padding-bottom:10px}h2{font-size:1rem;color:#333;margin-top:1.5rem;margin-bottom:.5rem;border-left:4px solid #6c5ce7;padding-left:10px}table{width:100%;border-collapse:collapse;margin:1rem 0}th{background:#f0f0ff;padding:8px 12px;text-align:left;font-size:.85rem}td{padding:8px 12px;border-bottom:1px solid #eee;font-size:.88rem}.positive{color:#00897b;font-weight:700}.negative{color:#c62828;font-weight:700}.highlight{background:#f0f0ff;font-weight:700}.right{text-align:right}.header-info{display:flex;justify-content:space-between;margin-bottom:2rem;color:#666;font-size:.85rem}button{margin-top:1rem;padding:10px 24px;background:#6c5ce7;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:1rem}@media print{button{display:none}}</style></head><body>
  <h1>RAPPORT FINANCIER ANNUEL — ProHub</h1>
  <div class="header-info"><span>Exercice : ${new Date().getFullYear()}</span><span>Généré le : ${new Date().toLocaleDateString('fr-FR')}</span><span>Entreprise : ${currentUser?.name||'—'}</span></div>
  <h2>Compte de résultat simplifié</h2>
  <table><tr><th>Poste</th><th class="right">Montant</th><th class="right">% CA</th></tr>
  <tr><td>Chiffre d'affaires</td><td class="right positive">${rev.toLocaleString('fr-FR')} €</td><td class="right">100%</td></tr>
  <tr><td>Charges d'exploitation</td><td class="right negative">${dep.toLocaleString('fr-FR')} €</td><td class="right">${rev>0?Math.round(dep/rev*100):0}%</td></tr>
  ${sal>0?`<tr><td>  dont masse salariale</td><td class="right" style="color:#666">${(sal*12).toLocaleString('fr-FR')} €/an</td><td class="right" style="color:#666">${rev>0?Math.round(sal*12/rev*100):0}%</td></tr>`:''}
  <tr class="highlight"><td><strong>Résultat net</strong></td><td class="right ${net>=0?'positive':'negative'}">${net.toLocaleString('fr-FR')} €</td><td class="right ${net>=0?'positive':'negative'}">${margin}%</td></tr></table>
  <h2>Détail des charges par catégorie</h2>
  <table><tr><th>Catégorie</th><th class="right">Montant</th><th class="right">% charges</th></tr>
  ${Object.entries(cats).sort((a,b)=>b[1]-a[1]).map(([k,v])=>`<tr><td>${k}</td><td class="right">${v.toLocaleString('fr-FR')} €</td><td class="right">${dep>0?Math.round(v/dep*100):0}%</td></tr>`).join('')}</table>
  <h2>Indicateurs de performance</h2>
  <table><tr><th>KPI</th><th class="right">Valeur</th><th>Interprétation</th></tr>
  <tr><td>Marge nette</td><td class="right">${margin}%</td><td>${margin>20?'✅ Excellent':margin>10?'🟡 Correct':'🔴 À améliorer'}</td></tr>
  <tr><td>Ratio charges/CA</td><td class="right">${rev>0?Math.round(dep/rev*100):0}%</td><td>${rev>0&&dep/rev<0.6?'✅ Bien maîtrisé':'⚠️ À surveiller'}</td></tr>
  <tr><td>Transactions revenus</td><td class="right">${txs.filter(t=>t.type==='revenu').length}</td><td>Factures / encaissements</td></tr>
  <tr><td>Transactions charges</td><td class="right">${txs.filter(t=>t.type==='depense').length}</td><td>Achats / décaissements</td></tr>
  ${crmContacts.length?`<tr><td>Clients actifs (CRM)</td><td class="right">${crmContacts.filter(c=>c.status==='client').length}</td><td>sur ${crmContacts.length} contacts total</td></tr>`:''}
  </table>
  <button onclick="window.print()">🖨️ Imprimer / Enregistrer en PDF</button>
  </body></html>`);w.document.close();
}

// UTILS
function showA(id,msg,cls){const el=document.getElementById(id);if(!el)return;el.className='alert '+cls+' show';el.textContent=msg;clearTimeout(el._t);el._t=setTimeout(()=>el.classList.remove('show'),3500);}
</script>
