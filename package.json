function toggleChat(){document.getElementById('cwin').classList.toggle('open');}
function sendMsg(){const inp=document.getElementById('ci2'),msg=inp.value.trim();if(!msg)return;inp.value='';const userEl=document.createElement('div');userEl.className='msg mu';userEl.textContent=msg;const c=document.getElementById('cmsg');c.appendChild(userEl);c.scrollTop=c.scrollHeight;const typing=document.createElement('div');typing.className='msg mb2';typing.innerHTML='<div class="typing"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>';c.appendChild(typing);c.scrollTop=c.scrollHeight;setTimeout(()=>{typing.remove();const lower=msg.toLowerCase();const k=Object.keys(BR).find(k=>lower.includes(k));addBotMsg(k?BR[k]:'Essaie : csv, devis, produit, tva, premium, aide.');},700);}
function ask(msg){document.getElementById('ci2').value=msg;document.getElementById('cwin').classList.add('open');sendMsg();}
