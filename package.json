// HOME MODULES
function renderHomeModules(){const isPrem=hasPremium(currentUser),isPP2=hasPP2(currentUser);const modules=[{id:'analyse',ico:'📊',name:'Analyser mes données',desc:'CSV → graphiques automatiques.',badge:'mb-b',min:'free'},{id:'devis',ico:'📄',name:'Devis & Factures',desc:'Devis pro + export PDF.',badge:'mb-p',min:'free'},{id:'produits',ico:'🛒',name:'Produits à revendre',desc:'Analyse les marges.',badge:'mb-g',min:'free'},{id:'contenu',ico:'✍️',name:'Créateur de contenu',desc:'Posts, emails, slogans.',badge:'mb-o',min:'free'},{id:'budget',ico:'💰',name:'Budget Tracker',desc:'Revenus & dépenses.',badge:'mb-g',min:'free'},{id:'crypto',ico:'🪙',name:'Crypto Dashboard',desc:'BTC, ETH, SOL live.',badge:'mb-b',min:'premium'},{id:'rentab',ico:'📈',name:'Rentabilité',desc:'Freelance, drop, invest.',badge:'mb-o',min:'premium'},{id:'posts',ico:'✍️',name:'Posts viraux',desc:'Réseaux sociaux.',badge:'mb-p',min:'premium'},{id:'tva',ico:'🧾',name:'Calculateur TVA',desc:'Auto-entrepreneur & SASU.',badge:'mb-o',min:'premium'},{id:'contrats',ico:'📝',name:'Contrats PDF',desc:'Contrats freelance pro.',badge:'mb-p',min:'premium'},{id:'equipe',ico:'👥',name:'Gestion équipe',desc:'Collaborateurs & rôles.',badge:'mb-pp2',min:'premium2'},{id:'emails',ico:'📧',name:'Emails en masse',desc:'Campagnes clients réelles.',badge:'mb-pp2',min:'premium2'},{id:'agenda',ico:'📅',name:'Agenda',desc:'Rappels & deadlines.',badge:'mb-pp2',min:'premium2'},{id:'notes',ico:'📒',name:'Notes rapides',desc:'Bloc-notes persistant.',badge:'mb-pp2',min:'premium2'},{id:'kpis',ico:'🎯',name:'Objectifs & KPIs',desc:'Suis ta progression.',badge:'mb-pp2',min:'premium2'},{id:'recurrents',ico:'🔁',name:'Factures récurrentes',desc:'MRR automatique.',badge:'mb-pp2',min:'premium2'},{id:'workspace',ico:'🏢',name:'Espace Entreprise',desc:'Invitez votre équipe.',badge:'mb-pp2',min:'premium2'},{id:'crm',ico:'👤',name:'CRM Clients',desc:'Prospects, leads, pipeline.',badge:'mb-g',min:'enterprise'},{id:'hr',ico:'🧑‍💼',name:'RH & Paie',desc:'Employés, congés, masse salariale.',badge:'mb-g',min:'enterprise'},{id:'reporting',ico:'📊',name:'Reporting Financier',desc:'Bilan, prévisions, FEC, Excel.',badge:'mb-g',min:'enterprise'},{id:'budgetent',ico:'🎯',name:'Budget Prévisionnel',desc:'Plan annuel mensuel vs réel.',badge:'mb-g',min:'enterprise'},{id:'excel',ico:'📗',name:'Import/Export Excel',desc:'Importez et exportez en .xlsx.',badge:'mb-g',min:'enterprise'}];document.getElementById('homeModules').innerHTML=modules.map(m=>{const isEnt2=isEnterprise(currentUser);const ok=(m.min==='free')||(m.min==='premium'&&isPrem)||(m.min==='premium2'&&isPP2)||(m.min==='enterprise'&&isEnt2);const isPP2lock=(m.min==='premium2'&&!isPP2)||(m.min==='enterprise'&&!isEnt2);const lc=isPP2lock?'lbpp2':'lbp';const lt=m.min==='enterprise'?'🏢 Entreprise':isPP2lock?'💎 Premium+':'⭐ Premium';const action=ok?`go('${m.id}',null)`:`go('tarifs',null)`;return`<div class="mc${ok?'':' locked'}" onclick="${action}">${ok?'':'<div class="lock-badge '+lc+'">'+lt+'</div>'}<span class="mc-ico">${m.ico}</span><div class="mc-n">${m.name}</div><div class="mc-d">${m.desc}</div><span class="mb-badge ${m.badge}">${m.min==='free'?'Gratuit':m.min==='premium'?'⭐ Premium':m.min==='enterprise'?'🏢 Entreprise':'💎 Premium+'}</span></div>`;}).join('');}

// ANNOUNCEMENTS
async function loadAnnouncements(){try{const anns=await API.get('/api/announcements');const c=document.getElementById('annBanners');if(!c)return;c.innerHTML=anns.map(a=>`<div class="ann-banner ann-${a.type}">${a.message}</div>`).join('');}catch(e){}}

// ADMIN
async function loadAdminData(){adminUsers=await API.get('/api/admin/users');renderAdminStats();renderAdminUsers();loadAdminAnnonces();}

function renderAdminStats(){const total=adminUsers.length,prem=adminUsers.filter(u=>u.role==='premium').length,pp2=adminUsers.filter(u=>u.role==='premium2').length,free=adminUsers.filter(u=>u.role==='free').length,mrr=prem*20+pp2*35,today=new Date().toDateString(),newToday=adminUsers.filter(u=>new Date(u.createdAt).toDateString()===today).length,conv=total>0?(((prem+pp2)/total)*100).toFixed(1):0;document.getElementById('adminStats').innerHTML=`<div class="stat"><div class="sa" style="background:var(--accent)"></div><div class="sl">Utilisateurs</div><div class="sv">${total}</div></div><div class="stat"><div class="sa" style="background:var(--gold)"></div><div class="sl">Premium</div><div class="sv">${prem}</div></div><div class="stat"><div class="sa" style="background:var(--pp2)"></div><div class="sl">Premium+</div><div class="sv">${pp2}</div></div><div class="stat"><div class="sa" style="background:var(--a3)"></div><div class="sl">MRR</div><div class="sv">${mrr} €</div></div>`;document.getElementById('adminMRR').textContent=mrr+' €';document.getElementById('adminARR').textContent=(mrr*12)+' €';document.getElementById('adminPP2cnt').textContent=pp2;document.getElementById('adminPPcnt').textContent=prem;document.getElementById('adminConv').textContent=conv+'%';document.getElementById('adminToday').textContent=newToday;setTimeout(()=>{if(adminChPlan)adminChPlan.destroy();adminChPlan=new Chart(document.getElementById('adminChPlan').getContext('2d'),{type:'doughnut',data:{labels:['Gratuit','Premium','Premium+','Admin'],datasets:[{data:[free,prem,pp2,adminUsers.filter(u=>u.role==='admin').length],backgroundColor:['#6c5ce7','#fdcb6e','#a29bfe','#fd79a8'],borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:'#7a7a9a'}}}}});if(adminChReg)adminChReg.destroy();adminChReg=new Chart(document.getElementById('adminChReg').getContext('2d'),{type:'bar',data:{labels:['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'],datasets:[{data:[0,0,0,0,0,0,0].map(()=>Math.floor(Math.random()*5)),backgroundColor:'rgba(108,92,231,0.6)',borderColor:'#6c5ce7',borderWidth:1,borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}});if(adminChRev)adminChRev.destroy();const months=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];adminChRev=new Chart(document.getElementById('adminChRev').getContext('2d'),{type:'line',data:{labels:months,datasets:[{label:'MRR (€)',data:months.map((_,i)=>Math.round((mrr||50)*(0.5+i*0.05+Math.random()*0.1))),borderColor:'#00cec9',backgroundColor:'rgba(0,206,201,0.08)',fill:true,tension:0.4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a'}}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}});},100);}

function renderAdminUsers(){const q=(document.getElementById('adminSearch')?.value||'').toLowerCase(),f=document.getElementById('adminFilter')?.value||'';const filtered=adminUsers.filter(u=>(!q||(u.name+u.email).toLowerCase().includes(q))&&(!f||u.role===f));const rC={free:'pb',premium:'py',premium2:'ppp2',enterprise:'pg',admin:'pr2'};const rL={free:'Gratuit',premium:'Premium ⭐',premium2:'Premium+ 💎',enterprise:'Entreprise 🏢',admin:'Admin 👑'};const colors=['#6c5ce7','#00cec9','#fdcb6e','#a29bfe','#fd79a8'];document.getElementById('adminUserList').innerHTML=filtered.map((u,i)=>{const subDate=u.subscribedAt?new Date(u.subscribedAt).toLocaleDateString('fr-FR'):'—';const regDate=new Date(u.createdAt).toLocaleDateString('fr-FR');return`<div class="user-row"><div class="ua" style="background:${colors[i%colors.length]}">${u.name.charAt(0).toUpperCase()}</div><div class="ua-info"><div style="font-size:.875rem;font-weight:600">${u.name}</div><div style="font-size:.73rem;color:var(--muted2)">${u.email}</div><div style="font-size:.68rem;color:var(--muted);margin-top:2px">Inscrit: ${regDate} ${u.role!=='free'?'• Abonné: '+subDate:''}</div></div><span class="pill ${rC[u.role]||'pb'}" style="margin-right:.5rem">${rL[u.role]||u.role}</span>${u.role!=='admin'?`<div class="ua-actions"><button style="background:rgba(253,203,110,.1);color:var(--gold);border-color:rgba(253,203,110,.3)" onclick="adminSetRole('${u.id}','premium')" title="Passer Premium">⭐</button><button style="background:rgba(162,155,254,.1);color:var(--pp2);border-color:rgba(162,155,254,.3)" onclick="adminSetRole('${u.id}','premium2')" title="Passer Premium+">💎</button><button style="background:rgba(0,206,201,.1);color:var(--a3);border-color:rgba(0,206,201,.3)" onclick="adminSetRole('${u.id}','enterprise')" title="Passer Entreprise">🏢</button><button style="background:rgba(255,120,120,.1);color:#ff8080;border-color:rgba(255,100,100,.3)" onclick="adminSetRole('${u.id}','free')" title="Rétrograder Gratuit">🔓</button><button style="background:rgba(108,92,231,.1);color:#b2acff;border-color:rgba(108,92,231,.3)" onclick="openModalPwd('${u.id}')" title="Changer mot de passe">🔑</button><button style="background:rgba(0,206,201,.1);color:var(--a3);border-color:rgba(0,206,201,.3)" onclick="openModalEdit('${u.id}','${u.name}','${u.email}')" title="Modifier infos">✏️</button><button style="background:rgba(255,60,60,.1);color:#ff7070;border-color:rgba(255,60,60,.2)" onclick="adminDelUser('${u.id}')" title="Supprimer">🗑</button></div>`:'<span style="font-size:.72rem;color:var(--muted)">Protégé</span>'}</div>`;}).join('')||'<div class="empty">Aucun utilisateur trouvé</div>';}

async function adminSetRole(id,role){const r=await API.patch('/api/admin/users/'+id+'/role',{role});if(r.error){alert(r.error);return;}await loadAdminData();}
async function adminDelUser(id){if(!confirm('Supprimer cet utilisateur ?'))return;await API.del('/api/admin/users/'+id);await loadAdminData();}

function openModalPwd(id){modalTargetId=id;document.getElementById('modalPwdNew').value='';document.getElementById('modalPwdConf').value='';document.getElementById('modalPwdAlert').classList.remove('show');document.getElementById('modalPwd').style.display='flex';}
async function submitAdminPwd(){const np=document.getElementById('modalPwdNew').value,cp=document.getElementById('modalPwdConf').value;if(np!==cp){showModalAlert('modalPwdAlert','Les mots de passe ne correspondent pas.','aer');return;}if(np.length<6){showModalAlert('modalPwdAlert','Minimum 6 caractères.','aer');return;}const r=await API.patch('/api/admin/users/'+modalTargetId+'/password',{newPassword:np});if(r.error){showModalAlert('modalPwdAlert',r.error,'aer');return;}closeModal('modalPwd');alert('✅ Mot de passe changé !');}

function openModalEdit(id,name,email){modalTargetId=id;document.getElementById('modalEditName').value=name;document.getElementById('modalEditEmail').value=email;document.getElementById('modalEditAlert').classList.remove('show');document.getElementById('modalEdit').style.display='flex';}
async function submitAdminEdit(){const n=document.getElementById('modalEditName').value.trim(),e=document.getElementById('modalEditEmail').value.trim();const r=await API.patch('/api/admin/users/'+modalTargetId+'/info',{name:n,email:e});if(r.error){showModalAlert('modalEditAlert',r.error,'aer');return;}closeModal('modalEdit');await loadAdminData();}

function closeModal(id){document.getElementById(id).style.display='none';}
function showModalAlert(id,msg,cls){const el=document.getElementById(id);el.className='alert '+cls+' show';el.textContent=msg;}

function swAdminTab(id,btn){['overview','users','revenue','annonces'].forEach(t=>{const el=document.getElementById('adminTab-'+t);if(el)el.style.display='none';});document.querySelectorAll('.admin-tab').forEach(b=>b.classList.remove('active'));document.getElementById('adminTab-'+id).style.display='block';btn.classList.add('active');if(id==='overview')setTimeout(renderAdminStats,50);if(id==='users')renderAdminUsers();if(id==='annonces')loadAdminAnnonces();}

async function loadAdminAnnonces(){try{const anns=await API.get('/api/announcements');document.getElementById('annList').innerHTML=anns.length?anns.map(a=>`<div style="display:flex;align-items:center;gap:.75rem;padding:.75rem 0;border-bottom:1px solid var(--border)"><span class="ann-banner ann-${a.type}" style="flex:1;margin:0">${a.message}</span><span style="font-size:.72rem;color:var(--muted2)">${new Date(a.createdAt).toLocaleDateString('fr-FR')}</span><button class="btn bd bsm" onclick="delAnnonce('${a.id}')">✕</button></div>`).join(''):'<div class="empty">Aucune annonce</div>';}catch(e){}}
async function postAnnonce(){const m=document.getElementById('annMsg').value.trim(),t=document.getElementById('annType').value;if(!m)return;await API.post('/api/admin/announcements',{message:m,type:t});document.getElementById('annMsg').value='';loadAdminAnnonces();loadAnnouncements();}
async function delAnnonce(id){await API.del('/api/admin/announcements/'+id);loadAdminAnnonces();loadAnnouncements();}

// PROFIL - see renderSettingsProfile in V4 SETTINGS block above
async function changePassword(){const op=document.getElementById('pwOld').value,np=document.getElementById('pwNew').value,cp=document.getElementById('pwConf').value;if(np!==cp){showA('pwAlert','Les mots de passe ne correspondent pas.','aer');return;}const r=await API.post('/api/auth/change-password',{currentPassword:op,newPassword:np});if(r.error){showA('pwAlert',r.error,'aer');return;}showA('pwAlert','✅ Mot de passe changé !','aok');['pwOld','pwNew','pwConf'].forEach(id=>document.getElementById(id).value='');}

// BUDGET
let txs=[],chP,chB;
function addTx(){const d=document.getElementById('bd').value.trim(),a=parseFloat(document.getElementById('ba').value),t=document.getElementById('bt').value,c=document.getElementById('bc').value;if(!d||!a||a<=0){alert('Remplis tous les champs !');return;}txs.push({d,a,t,c,dt:new Date().toLocaleDateString('fr-FR')});document.getElementById('bd').value='';document.getElementById('ba').value='';rBudget();}
function delTx(i){txs.splice(i,1);rBudget();}
function rBudget(){const rv=txs.filter(t=>t.t==='revenu').reduce((s,t)=>s+t.a,0),dp=txs.filter(t=>t.t==='depense').reduce((s,t)=>s+t.a,0),sl=rv-dp,ep=rv>0?((sl/rv)*100).toFixed(1):0;document.getElementById('sr').textContent=rv.toFixed(2)+' €';document.getElementById('sd').textContent=dp.toFixed(2)+' €';document.getElementById('ss').textContent=sl.toFixed(2)+' €';document.getElementById('se').textContent=ep+'%';document.getElementById('src').textContent=txs.filter(t=>t.t==='revenu').length+' entrées';document.getElementById('sdc').textContent=txs.filter(t=>t.t==='depense').length+' entrées';const e=document.getElementById('sss');e.textContent=sl>=0?'✅ Positif':'⚠️ Négatif';e.className='sub '+(sl>=0?'pos':'neg');document.getElementById('be').style.display=txs.length?'none':'block';document.getElementById('bl').innerHTML=txs.map((t,i)=>`<tr><td>${t.d}</td><td><span class="bpu">${t.c}</span></td><td><span class="${t.t==='revenu'?'bg3pill':'br2pill'}">${t.t==='revenu'?'↑ Revenu':'↓ Dépense'}</span></td><td style="color:${t.t==='revenu'?'var(--a3)':'#ff7070'};font-weight:700">${t.t==='revenu'?'+':'-'}${t.a.toFixed(2)} €</td><td><button class="bd2" onclick="delTx(${i})">✕</button></td></tr>`).join('');const cats={};txs.filter(t=>t.t==='depense').forEach(t=>{cats[t.c]=(cats[t.c]||0)+t.a;});const cols=['#00cec9','#7c3aed','#fdcb6e','#ff4466','#06b6d4','#ec4899'];if(chP)chP.destroy();chP=new Chart(document.getElementById('chp').getContext('2d'),{type:'doughnut',data:{labels:Object.keys(cats).length?Object.keys(cats):['Aucune'],datasets:[{data:Object.values(cats).length?Object.values(cats):[1],backgroundColor:cols,borderWidth:0}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:'#7a7a9a',font:{size:10}}}}}});const mn={};txs.forEach(t=>{const m=t.dt.split('/').slice(1).join('/');if(!mn[m])mn[m]={r:0,d:0};if(t.t==='revenu')mn[m].r+=t.a;else mn[m].d+=t.a;});if(chB)chB.destroy();chB=new Chart(document.getElementById('chb').getContext('2d'),{type:'bar',data:{labels:Object.keys(mn).length?Object.keys(mn):['—'],datasets:[{label:'Revenus',data:Object.values(mn).map(m=>m.r),backgroundColor:'#00cec966',borderColor:'#00cec9',borderWidth:1,borderRadius:4},{label:'Dépenses',data:Object.values(mn).map(m=>m.d),backgroundColor:'#ff446666',borderColor:'#ff4466',borderWidth:1,borderRadius:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a'}}},scales:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}});}
setTimeout(()=>{[{d:'Salaire',a:2500,t:'revenu',c:'Salaire / Freelance'},{d:'Freelance',a:800,t:'revenu',c:'Salaire / Freelance'},{d:'Loyer',a:900,t:'depense',c:'Logement'},{d:'Courses',a:250,t:'depense',c:'Alimentation'},{d:'Transport',a:120,t:'depense',c:'Transport'}].forEach(t=>{t.dt=new Date().toLocaleDateString('fr-FR');txs.push(t);});rBudget();},200);

// CSV ANALYSER
let csvData=[],csvCols=[],chart=null;
const uz=document.getElementById('uz');
uz.addEventListener('dragover',e=>{e.preventDefault();uz.classList.add('drag');});
uz.addEventListener('dragleave',()=>uz.classList.remove('drag'));
uz.addEventListener('drop',e=>{e.preventDefault();uz.classList.remove('drag');handleFile({target:{files:e.dataTransfer.files}});});
function handleFile(e){const f=e.target.files[0];if(!f)return;Papa.parse(f,{header:true,skipEmptyLines:true,dynamicTyping:true,complete:r=>{csvData=r.data;csvCols=r.meta.fields;uz.innerHTML=`<div class="ui">✅</div><div style="color:var(--muted2);font-size:.875rem"><strong>${f.name}</strong> — ${csvData.length} lignes</div>`;renderStats();renderTable();const o=csvCols.map(c=>`<option value="${c}">${c}</option>`).join('');document.getElementById('gX').innerHTML=o;document.getElementById('gY').innerHTML=o;document.getElementById('ac').style.display='block';}});}
function renderStats(){const nc=csvCols.filter(c=>typeof csvData[0][c]==='number');const cl=['var(--accent)','var(--a2)','var(--a3)','var(--gold)'];document.getElementById('csvStats').innerHTML=nc.slice(0,4).map((c,i)=>{const v=csvData.map(r=>r[c]).filter(x=>!isNaN(x));const s=v.reduce((a,b)=>a+b,0);return`<div class="stat"><div class="sa" style="background:${cl[i]}"></div><div class="sl">${c}</div><div class="sv">${s.toLocaleString('fr-FR')}</div><div class="sn">Moy:${(s/v.length).toFixed(1)}</div></div>`;}).join('')+`<div class="stat"><div class="sa" style="background:var(--muted)"></div><div class="sl">Lignes</div><div class="sv">${csvData.length}</div></div>`;}
function renderTable(){document.getElementById('csvTbl').innerHTML=`<thead><tr>${csvCols.map(c=>`<th>${c}</th>`).join('')}</tr></thead><tbody>${csvData.slice(0,10).map(r=>`<tr>${csvCols.map(c=>`<td>${r[c]??'—'}</td>`).join('')}</tr>`).join('')}</tbody>`;}
const CLRS=['#6c5ce7','#fd79a8','#00cec9','#fdcb6e','#7c3aed','#06b6d4'];
function makeChart(){const x=document.getElementById('gX').value,y=document.getElementById('gY').value,t=document.getElementById('gT').value;const labs=csvData.map(r=>String(r[x])),vals=csvData.map(r=>parseFloat(r[y])||0);if(chart)chart.destroy();const isPie=t==='pie';chart=new Chart(document.getElementById('myChart').getContext('2d'),{type:t,data:{labels:labs,datasets:[{label:y,data:vals,backgroundColor:isPie?CLRS:'rgba(108,92,231,0.7)',borderColor:isPie?CLRS:'#6c5ce7',borderWidth:1,fill:t==='line',tension:0.4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:'#7a7a9a'}}},scales:isPie?{}:{x:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}},y:{ticks:{color:'#4a4a6a'},grid:{color:'rgba(255,255,255,0.04)'}}}}})}

// DEVIS
let dvList=[],dvId=1;
function addLine(){const d=document.createElement('div');d.className='dl';d.innerHTML=`<input placeholder="Prestation" oninput="calcT()"><input type="number" value="1" min="1" style="text-align:center" oninput="calcT()"><input type="number" placeholder="Prix €" oninput="calcT()"><button class="btn bd" onclick="this.closest('.dl').remove();calcT()">✕</button>`;document.getElementById('dlines').appendChild(d);}
function calcT(){let t=0;document.querySelectorAll('.dl').forEach(l=>{const i=l.querySelectorAll('input');t+=(parseFloat(i[1].value)||0)*(parseFloat(i[2].value)||0);});document.getElementById('dtv').textContent=t.toFixed(2).replace('.',',')+' €';return t;}
function creerDevis(){const c=document.getElementById('dc').value.trim(),o=document.getElementById('do2').value.trim();if(!c||!o){showA('da','⚠️ Remplis client et objet.','aer');return;}const lg=[];document.querySelectorAll('.dl').forEach(l=>{const i=l.querySelectorAll('input');lg.push({d:i[0].value,q:parseFloat(i[1].value)||1,p:parseFloat(i[2].value)||0});});const tot=lg.reduce((a,l)=>a+l.q*l.p,0);dvList.push({id:dvId++,c,o,lg,tot,date:new Date().toLocaleDateString('fr-FR'),s:'en attente'});document.getElementById('dc').value='';document.getElementById('do2').value='';document.getElementById('dlines').innerHTML='';addLine();calcT();showA('da','✅ Devis créé !','aok');renderDevis();}
function renderDevis(){const b=document.getElementById('db');if(!dvList.length){b.innerHTML='<tr><td colspan="7"><div class="empty">Aucun devis</div></td></tr>';return;}const pill=s=>s==='accepté'?'pg':s==='refusé'?'pr2':'py';b.innerHTML=[...dvList].reverse().map(d=>`<tr><td>#${d.id}</td><td>${d.c}</td><td>${d.o}</td><td style="color:var(--a3);font-weight:700">${d.tot.toFixed(2)} €</td><td>${d.date}</td><td><span class="pill ${pill(d.s)}">${d.s}</span></td><td style="display:flex;gap:4px"><button class="btn bg2 bsm" onclick="setSt(${d.id},'accepté')">✓</button><button class="btn bd" onclick="setSt(${d.id},'refusé')">✕</button></td></tr>`).join('');}
function setSt(id,s){const d=dvList.find(x=>x.id===id);if(d)d.s=s;renderDevis();}
function printDevis(){const c=document.getElementById('dc').value||'Client',o=document.getElementById('do2').value||'Prestation';let lh='',tot=0;document.querySelectorAll('.dl').forEach(l=>{const i=l.querySelectorAll('input');const q=parseFloat(i[1].value)||1,p=parseFloat(i[2].value)||0,st=q*p;tot+=st;lh+=`<tr><td>${i[0].value||'—'}</td><td>${q}</td><td>${p.toFixed(2)} €</td><td>${st.toFixed(2)} €</td></tr>`;});const w=window.open('','_blank');w.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Devis</title><style>body{font-family:Arial;padding:40px;color:#111;max-width:700px;margin:auto}table{width:100%;border-collapse:collapse;margin:1.5rem 0}th{background:#f5f5f5;padding:8px 12px;text-align:left}td{padding:8px 12px;border-bottom:1px solid #eee}.tot{text-align:right;font-size:1.2rem;font-weight:700}button{margin-top:1rem;padding:8px 20px;background:#6c5ce7;color:#fff;border:none;border-radius:8px;cursor:pointer}@media print{button{display:none}}</style></head><body><h1>DEVIS</h1><h2>${o}</h2><p><strong>Client:</strong> ${c}</p><p><strong>Date:</strong> ${new Date().toLocaleDateString('fr-FR')}</p><table><thead><tr><th>Description</th><th>Qté</th><th>Prix</th><th>Total</th></tr></thead><tbody>${lh}</tbody></table><p class="tot">Total HT: ${tot.toFixed(2)} €</p><button onclick="window.print()">Imprimer / PDF</button></body></html>`);w.document.close();}

// PRODUITS
let prods=[{n:'Coques téléphone',cat:'High-tech',a:3,v:18},{n:'Écouteurs reconditionnés',cat:'High-tech',a:25,v:70},{n:'Vêtements vintage',cat:'Mode',a:8,v:35},{n:'Sneakers rétro',cat:'Mode',a:30,v:95},{n:'Bougies artisanales',cat:'Maison',a:4,v:20},{n:'Soins naturels',cat:'Beauté',a:6,v:22},{n:'Accessoires yoga',cat:'Sport',a:10,v:35}];
function addProd(){const n=document.getElementById('pnom').value.trim(),cat=document.getElementById('pcat4').value,a=parseFloat(document.getElementById('pa').value),v=parseFloat(document.getElementById('pv').value);if(!n||isNaN(a)||isNaN(v))return;prods.unshift({n,cat,a,v});['pnom','pa','pv'].forEach(id=>document.getElementById(id).value='');renderProd();}
function renderProd(){const s=document.getElementById('ps').value.toLowerCase(),cat=document.getElementById('pcat3').value;let list=prods.filter(p=>(!cat||p.cat===cat)&&(!s||p.n.toLowerCase().includes(s)));list.sort((a,b)=>(b.v-b.a)/b.a-(a.v-a.a)/a.a);document.getElementById('pg').innerHTML=list.map(p=>{const m=Math.round((p.v-p.a)/p.a*100),cls=m>=150?'mh':m>=80?'mm':'ml',fc=m>=150?'var(--a3)':m>=80?'var(--gold)':'#ff7070';return`<div class="pc"><div class="pnm">${p.n}</div><div class="pcat">${p.cat}</div><div class="ppx"><span style="color:var(--muted2)">Achat</span><span>${p.a} €</span></div><div class="ppx"><span style="color:var(--muted2)">Vente</span><span style="color:var(--a3)">${p.v} €</span></div><div class="pmb"><div class="pmf" style="width:${Math.min(100,m/3)}%;background:${fc}"></div></div><div class="pm"><span style="font-size:.72rem;color:var(--muted2)">Marge</span><span class="pmv ${cls}">+${m}%</span></div></div>`;}).join('');}

