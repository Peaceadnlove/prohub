<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ProHub — Suite Business v4</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/papaparse@5.4.1/papaparse.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
<style>
:root{--bg:#07070f;--bg2:#0d0d1a;--bg3:#13132a;--card:#0f0f20;--border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.14);--accent:#6c5ce7;--a2:#fd79a8;--a3:#00cec9;--gold:#fdcb6e;--pp2:#a29bfe;--text:#f0f0ff;--muted:#4a4a6a;--muted2:#7a7a9a;--r:10px;--rl:14px;}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;overflow-x:hidden;}
.auth-overlay{position:fixed;inset:0;background:var(--bg);z-index:9999;display:flex;align-items:center;justify-content:center;padding:1rem;}
.auth-box{background:var(--card);border:1px solid var(--border2);border-radius:20px;padding:2.5rem;width:100%;max-width:460px;box-shadow:0 0 60px rgba(108,92,231,.15);}
.auth-logo{font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:800;text-align:center;margin-bottom:.2rem;}
.auth-logo span{color:var(--a2);}
.auth-sub{text-align:center;color:var(--muted2);font-size:.83rem;margin-bottom:2rem;}
.auth-tabs{display:flex;margin-bottom:1.75rem;background:var(--bg3);border-radius:var(--r);padding:4px;}
.auth-tab{flex:1;padding:.55rem;text-align:center;font-size:.85rem;font-weight:600;cursor:pointer;border-radius:8px;transition:all .2s;color:var(--muted2);}
.auth-tab.active{background:var(--accent);color:#fff;}
.auth-form{display:flex;flex-direction:column;gap:.75rem;}
.auth-fg{display:flex;flex-direction:column;gap:5px;}
.auth-lbl{font-size:.73rem;color:var(--muted2);font-weight:500;}
.auth-err{background:rgba(255,60,60,.08);border:1px solid rgba(255,60,60,.2);color:#ff7070;padding:.6rem .9rem;border-radius:var(--r);font-size:.82rem;display:none;}
.auth-err.show{display:block;}
.auth-ok{background:rgba(0,206,201,.08);border:1px solid rgba(0,206,201,.2);color:var(--a3);padding:.6rem .9rem;border-radius:var(--r);font-size:.82rem;display:none;}
.auth-ok.show{display:block;}
.plan-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:.5rem;}
.plan-opt{border:1px solid var(--border);border-radius:var(--r);padding:.65rem;cursor:pointer;text-align:center;transition:all .2s;position:relative;}
.plan-opt.sel{border-color:var(--accent);background:rgba(108,92,231,.1);}
.plan-opt.sel-pp2{border-color:var(--pp2);background:rgba(162,155,254,.1);}
.plan-opt .pi{font-size:1.2rem;}.plan-opt .pn{font-size:.75rem;font-weight:700;margin-top:3px;}.plan-opt .pp{font-size:.65rem;color:var(--muted2);}
.plan-opt .pop-tag{position:absolute;top:-8px;right:4px;background:var(--a2);color:#fff;font-size:.55rem;font-weight:700;padding:1px 5px;border-radius:8px;}
.code-inputs{display:flex;gap:.5rem;justify-content:center;margin:.5rem 0;}
.code-input{width:48px;height:56px;text-align:center;font-size:1.4rem;font-weight:700;background:var(--bg3);border:2px solid var(--border2);color:var(--text);border-radius:var(--r);outline:none;transition:border-color .2s;}
.code-input:focus{border-color:var(--accent);}
.layout{display:grid;grid-template-columns:250px 1fr;min-height:100vh;}
.sidebar{background:var(--bg2);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto;}
.logo{padding:1.5rem 1.5rem 1rem;border-bottom:1px solid var(--border);}
.logo-t{font-family:'Syne',sans-serif;font-size:1.4rem;font-weight:800;}
.logo-t span{color:var(--a2);}
.logo-s{font-size:.67rem;color:var(--muted2);margin-top:2px;letter-spacing:1px;text-transform:uppercase;}
.nav{padding:1rem 0;flex:1;}
.nav-sec{padding:.5rem 1.5rem .25rem;font-size:.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:1.5px;margin-top:.5rem;}
.ni{display:flex;align-items:center;gap:10px;padding:.65rem 1.5rem;cursor:pointer;color:var(--muted2);font-size:.875rem;font-weight:500;transition:all .15s;border-left:3px solid transparent;}
.ni:hover{color:var(--text);background:rgba(255,255,255,.025);}
.ni.active{color:var(--text);border-left-color:var(--accent);background:rgba(108,92,231,.08);}
.ni-ico{font-size:1rem;width:22px;text-align:center;}
.ni .lock{font-size:.62rem;margin-left:auto;padding:1px 5px;border-radius:4px;}
.lock-p{background:rgba(253,203,110,.12);color:var(--gold);}
.lock-pp2{background:rgba(162,155,254,.12);color:var(--pp2);}
.sb-bot{padding:1rem 1.5rem;border-top:1px solid var(--border);}
.user-pill{display:flex;align-items:center;gap:8px;margin-bottom:.75rem;}
.user-av{width:34px;height:34px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:700;flex-shrink:0;}
.user-name{font-size:.82rem;font-weight:600;}
.live{display:inline-flex;align-items:center;gap:6px;font-size:.72rem;padding:4px 10px;border-radius:20px;border:1px solid;}
.live.free{background:rgba(108,92,231,.1);color:#b2acff;border-color:rgba(108,92,231,.2);}
.live.premium{background:rgba(253,203,110,.1);color:var(--gold);border-color:rgba(253,203,110,.2);}
.live.premium2{background:rgba(162,155,254,.1);color:var(--pp2);border-color:rgba(162,155,254,.2);}
.live.admin{background:rgba(253,121,168,.1);color:#ffb3cc;border-color:rgba(253,121,168,.2);}
.live.enterprise{background:rgba(0,206,201,.1);color:var(--a3);border-color:rgba(0,206,201,.3);}
.live::before{content:'';width:6px;height:6px;border-radius:50%;display:inline-block;animation:pulse2 2s infinite;}
.live.free::before{background:#b2acff;}.live.premium::before{background:var(--gold);}.live.premium2::before{background:var(--pp2);}.live.enterprise::before{background:var(--a3);}.live.admin::before{background:#ffb3cc;}
@keyframes pulse2{0%,100%{opacity:1;}50%{opacity:.3;}}
.main{overflow-y:auto;}
.page{display:none;padding:2.5rem;min-height:100vh;animation:fu .25s ease;}
.page.active{display:block;}
@keyframes fu{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.ph{margin-bottom:2rem;}
.pt{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;letter-spacing:-1px;line-height:1.1;}
.pt span{color:var(--accent);}
.pd{color:var(--muted2);font-size:.875rem;margin-top:.4rem;}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);padding:1.5rem;margin-bottom:1.25rem;}
.ct{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;margin-bottom:1.25rem;display:flex;justify-content:space-between;align-items:center;gap:1rem;}
.sg{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:1rem;margin-bottom:1.5rem;}
.stat{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:1.25rem;position:relative;overflow:hidden;}
.sa{position:absolute;top:0;left:0;right:0;height:2px;}
.sl{font-size:.7rem;color:var(--muted2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:.5rem;}
.sv{font-family:'Syne',sans-serif;font-size:1.7rem;font-weight:800;}
.sn{font-size:.73rem;color:var(--muted2);margin-top:3px;}
.mg{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1.25rem;}
.mc{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);padding:1.5rem;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;}
.mc:hover{border-color:var(--border2);transform:translateY(-3px);box-shadow:0 8px 30px rgba(0,0,0,.3);}
.mc.locked{opacity:.5;cursor:not-allowed;}
.mc-ico{font-size:1.8rem;margin-bottom:.75rem;display:block;}
.mc-n{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;margin-bottom:.35rem;}
.mc-d{font-size:.78rem;color:var(--muted2);line-height:1.5;}
.mb-badge{display:inline-block;margin-top:.75rem;font-size:.68rem;padding:2px 9px;border-radius:20px;font-weight:600;}
.mb-b{background:rgba(108,92,231,.15);color:#b2acff;}.mb-p{background:rgba(253,121,168,.12);color:#ffb3cc;}.mb-g{background:rgba(0,206,201,.12);color:var(--a3);}.mb-o{background:rgba(253,203,110,.12);color:var(--gold);}.mb-pp2{background:rgba(162,155,254,.12);color:var(--pp2);}
.lock-badge{position:absolute;top:.75rem;right:.75rem;font-size:.68rem;padding:2px 8px;border-radius:20px;border:1px solid;}
.lock-badge.lbp{background:rgba(253,203,110,.15);color:var(--gold);border-color:rgba(253,203,110,.25);}
.lock-badge.lbpp2{background:rgba(162,155,254,.15);color:var(--pp2);border-color:rgba(162,155,254,.25);}
.pricing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.25rem;margin-bottom:1.5rem;}
.pricing-card{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);padding:1.75rem;position:relative;transition:all .2s;}
.pricing-card:hover{border-color:var(--border2);transform:translateY(-4px);}
.pricing-card.featured{border-color:rgba(162,155,254,.4);box-shadow:0 0 40px rgba(162,155,254,.1);}
.pricing-badge{position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--accent),var(--pp2));color:#fff;font-size:.7rem;font-weight:700;padding:3px 12px;border-radius:20px;white-space:nowrap;}
.pricing-name{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:800;margin-bottom:.5rem;}
.pricing-price{font-family:'Syne',sans-serif;font-size:2.2rem;font-weight:800;margin-bottom:.25rem;}
.pricing-price span{font-size:.9rem;font-weight:400;color:var(--muted2);}
.pricing-yearly{font-size:.78rem;color:var(--a3);margin-bottom:1.25rem;}
.pricing-features{list-style:none;display:flex;flex-direction:column;gap:.6rem;margin-bottom:1.5rem;}
.pricing-features li{font-size:.83rem;display:flex;align-items:center;gap:8px;color:var(--muted2);}
.pricing-features li.yes{color:var(--text);}
.pricing-features li::before{content:'✓';color:var(--a3);font-weight:700;flex-shrink:0;}
.pricing-features li.no::before{content:'✕';color:var(--muted);}
.billing-toggle{display:flex;align-items:center;gap:.75rem;margin-bottom:1.5rem;justify-content:center;}
.toggle{width:44px;height:24px;background:var(--bg3);border-radius:12px;cursor:pointer;position:relative;border:1px solid var(--border2);}
.toggle.on{background:var(--accent);}
.toggle::after{content:'';position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:#fff;transition:transform .2s;}
.toggle.on::after{transform:translateX(20px);}
.upgrade-banner{background:linear-gradient(135deg,rgba(253,203,110,.1),rgba(108,92,231,.08));border:1px solid rgba(253,203,110,.2);border-radius:var(--rl);padding:1.5rem;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
.pp2-banner{background:linear-gradient(135deg,rgba(162,155,254,.1),rgba(108,92,231,.06));border:1px solid rgba(162,155,254,.25);border-radius:var(--rl);padding:1.5rem;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
.ub-t{font-family:'Syne',sans-serif;font-size:1rem;font-weight:700;margin-bottom:.25rem;}
.ub-d{font-size:.82rem;color:var(--muted2);}
.ann-banner{border-radius:var(--r);padding:.75rem 1.25rem;margin-bottom:1rem;font-size:.85rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;}
.ann-info{background:rgba(108,92,231,.1);border:1px solid rgba(108,92,231,.2);color:#b2acff;}
.ann-success{background:rgba(0,206,201,.08);border:1px solid rgba(0,206,201,.2);color:var(--a3);}
.ann-warning{background:rgba(253,203,110,.08);border:1px solid rgba(253,203,110,.2);color:var(--gold);}
.fr{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:.75rem;margin-bottom:.75rem;}
.fg{display:flex;flex-direction:column;gap:5px;}
.fl{font-size:.73rem;color:var(--muted2);font-weight:500;}
input,select,textarea{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:.6rem .9rem;border-radius:var(--r);font-size:.875rem;font-family:'DM Sans',sans-serif;outline:none;transition:border-color .15s;width:100%;}
input:focus,select:focus,textarea:focus{border-color:rgba(108,92,231,.5);}
select option{background:var(--bg3);}
textarea{resize:vertical;min-height:80px;}
.btn{display:inline-flex;align-items:center;gap:6px;padding:.6rem 1.2rem;border-radius:var(--r);font-size:.875rem;font-weight:600;cursor:pointer;border:none;transition:all .15s;font-family:'DM Sans',sans-serif;white-space:nowrap;}
.btn:active{transform:scale(.97);}
.bp{background:var(--accent);color:#fff;}.bp:hover{background:#7d6ef0;}
.bg2{background:rgba(0,206,201,.12);color:var(--a3);border:1px solid rgba(0,206,201,.25);}
.bo{background:transparent;color:var(--text);border:1px solid var(--border2);}
.bd{background:rgba(255,60,60,.1);color:#ff7070;border:1px solid rgba(255,60,60,.2);padding:.3rem .7rem;font-size:.78rem;}
.bsm{padding:.4rem .85rem;font-size:.8rem;}
.bgo{background:rgba(253,203,110,.12);color:var(--gold);border:1px solid rgba(253,203,110,.25);}
.bpp2{background:linear-gradient(135deg,rgba(162,155,254,.2),rgba(108,92,231,.2));color:var(--pp2);border:1px solid rgba(162,155,254,.3);}
.bred{background:rgba(255,60,60,.15);color:#ff7070;border:1px solid rgba(255,60,60,.2);}
.tw{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:.875rem;}
th{text-align:left;padding:.65rem 1rem;color:var(--muted2);font-size:.7rem;text-transform:uppercase;letter-spacing:.5px;border-bottom:1px solid var(--border);font-weight:600;}
td{padding:.85rem 1rem;border-bottom:1px solid rgba(255,255,255,.025);}
tr:last-child td{border-bottom:none;}
.pill{display:inline-block;padding:2px 9px;border-radius:20px;font-size:.7rem;font-weight:600;}
.pg{background:rgba(0,206,201,.1);color:var(--a3);}.py{background:rgba(253,203,110,.1);color:var(--gold);}.pr2{background:rgba(255,60,60,.08);color:#ff7070;}.pb{background:rgba(108,92,231,.12);color:#b2acff;}.ppp2{background:rgba(162,155,254,.12);color:var(--pp2);}
.uz{border:2px dashed var(--border2);border-radius:var(--rl);padding:2.5rem 2rem;text-align:center;cursor:pointer;transition:all .2s;}
.uz:hover,.uz.drag{border-color:var(--accent);background:rgba(108,92,231,.04);}
.ui{font-size:2.5rem;margin-bottom:.75rem;}
.cw{position:relative;height:280px;}
.cw2{position:relative;height:220px;}
.dl{display:grid;grid-template-columns:2.5fr .7fr 1fr auto;gap:.5rem;align-items:center;margin-bottom:.5rem;}
.dtl{display:flex;justify-content:flex-end;align-items:baseline;gap:.5rem;padding:.75rem 0;border-top:1px solid var(--border);}
.dtlb{color:var(--muted2);font-size:.85rem;}
.dtlv{font-family:'Syne',sans-serif;font-size:1.6rem;color:var(--a3);}
.pg2{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:1rem;margin-top:1rem;}
.pc{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:1.2rem;transition:all .2s;}
.pc:hover{border-color:var(--border2);transform:translateY(-2px);}
.pnm{font-weight:700;font-size:.9rem;margin-bottom:.3rem;}
.pcat{font-size:.7rem;color:var(--muted2);margin-bottom:.75rem;}
.ppx{display:flex;justify-content:space-between;font-size:.82rem;margin-bottom:3px;}
.pmb{height:4px;border-radius:2px;background:var(--border);margin-top:.65rem;overflow:hidden;}
.pmf{height:100%;border-radius:2px;}
.pm{display:flex;justify-content:space-between;align-items:center;margin-top:.65rem;padding-top:.65rem;border-top:1px solid var(--border);}
.pmv{font-family:'Syne',sans-serif;font-size:1.05rem;font-weight:800;}
.mh{color:var(--a3);}.mm{color:var(--gold);}.ml{color:#ff7070;}
.co{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:1.25rem;min-height:120px;font-size:.875rem;line-height:1.75;white-space:pre-wrap;}
.tg{display:flex;flex-wrap:wrap;gap:.5rem;margin-bottom:1rem;}
.tb{padding:.4rem 1rem;border-radius:20px;font-size:.78rem;cursor:pointer;border:1px solid var(--border2);background:transparent;color:var(--muted2);font-family:'DM Sans',sans-serif;transition:all .15s;font-weight:500;}
.tb:hover,.tb.active{background:rgba(108,92,231,.12);border-color:rgba(108,92,231,.4);color:#b2acff;}
.ctg{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:.5rem;margin-bottom:1rem;}
.cb{padding:.6rem;border-radius:var(--r);font-size:.8rem;cursor:pointer;border:1px solid var(--border);background:var(--bg3);color:var(--muted2);font-family:'DM Sans',sans-serif;text-align:center;transition:all .15s;font-weight:500;}
.cb:hover,.cb.active{border-color:rgba(108,92,231,.4);background:rgba(108,92,231,.07);color:var(--text);}
.ci{font-size:1.1rem;display:block;margin-bottom:3px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.2rem;}
@media(max-width:700px){.g2,.g4{grid-template-columns:1fr;}.layout{grid-template-columns:1fr;}.sidebar{display:none;}.page{padding:1.25rem;}}
.sc{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:1.2rem 1.5rem;position:relative;overflow:hidden;}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--sac,var(--accent));}
.sc .lbl{font-size:.7rem;color:var(--muted2);text-transform:uppercase;letter-spacing:1.5px;}
.sc .val{font-size:1.7rem;font-weight:800;letter-spacing:-1px;margin:.3rem 0;font-family:'Syne',monospace;}
.sc .sub{font-size:.75rem;color:var(--muted2);}
.pos{color:var(--a3)!important;}.neg{color:#ff7070!important;}
.bg3pill{background:rgba(0,206,201,.1);color:var(--a3);display:inline-block;padding:.18rem .55rem;border-radius:4px;font-size:.68rem;font-weight:700;}
.br2pill{background:rgba(255,70,70,.1);color:#ff7070;display:inline-block;padding:.18rem .55rem;border-radius:4px;font-size:.68rem;font-weight:700;}
.bpu{background:rgba(108,92,231,.12);color:#b2acff;display:inline-block;padding:.18rem .55rem;border-radius:4px;font-size:.68rem;font-weight:700;}
.bd2{background:transparent;color:#ff7070;border:1px solid rgba(255,70,70,.3);padding:.25rem .6rem;font-size:.72rem;border-radius:4px;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:700;}
.tabs2{display:flex;gap:.4rem;margin-bottom:1.5rem;flex-wrap:wrap;}
.tab2{padding:.45rem 1.1rem;border-radius:6px;border:1px solid var(--border);background:none;color:var(--muted2);cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.78rem;font-weight:600;transition:all .2s;}
.tab2.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.ob{background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:1.1rem;font-size:.82rem;line-height:1.75;white-space:pre-wrap;min-height:100px;color:var(--text);}
.dv{height:1px;background:var(--border);margin:1.5rem 0;}
.fab{position:fixed;bottom:2rem;right:2rem;width:52px;height:52px;background:var(--accent);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.3rem;z-index:1000;box-shadow:0 4px 24px rgba(108,92,231,.45);transition:transform .2s;}
.fab:hover{transform:scale(1.1);}
.cwin{position:fixed;bottom:5.5rem;right:2rem;width:350px;background:var(--bg2);border:1px solid var(--border2);border-radius:var(--rl);overflow:hidden;z-index:1000;display:none;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.6);}
.cwin.open{display:flex;}
.ch{padding:1rem 1.25rem;background:var(--accent);display:flex;align-items:center;gap:10px;}
.ca{width:32px;height:32px;background:rgba(255,255,255,.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
.cn2{font-weight:700;font-size:.9rem;font-family:'Syne',sans-serif;}.cs{font-size:.7rem;opacity:.8;}
.cm{height:300px;overflow-y:auto;padding:1rem;display:flex;flex-direction:column;gap:.75rem;}
.msg{max-width:86%;padding:.65rem .9rem;border-radius:14px;font-size:.83rem;line-height:1.5;}
.mb2{background:var(--bg3);border:1px solid var(--border);border-bottom-left-radius:4px;align-self:flex-start;}
.mu{background:var(--accent);color:#fff;border-bottom-right-radius:4px;align-self:flex-end;}
.chips{display:flex;flex-wrap:wrap;gap:.4rem;padding:.5rem 1rem;}
.chip{background:var(--bg3);border:1px solid var(--border);color:var(--muted2);padding:3px 9px;border-radius:20px;font-size:.72rem;cursor:pointer;transition:all .15s;font-family:'DM Sans',sans-serif;}
.chip:hover{border-color:rgba(108,92,231,.4);color:#b2acff;}
.cinp{display:flex;gap:.5rem;padding:.75rem;border-top:1px solid var(--border);}
.cinp input{flex:1;}
.cc{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:1.2rem;transition:all .2s;cursor:pointer;}
.cc:hover{border-color:rgba(0,206,201,.4);transform:translateY(-2px);}
.cc .sym{font-size:1rem;font-weight:800;}.cc .cn3{font-size:.7rem;color:var(--muted2);margin-bottom:.7rem;}
.cc .pr3{font-size:1.35rem;font-weight:700;font-family:'Syne',monospace;}.cc .ch3{font-size:.78rem;margin-top:.3rem;}
.alert{padding:.7rem 1rem;border-radius:var(--r);font-size:.84rem;margin-bottom:1rem;display:none;}
.alert.show{display:flex;align-items:center;gap:8px;}
.aok{background:rgba(0,206,201,.07);border:1px solid rgba(0,206,201,.2);color:var(--a3);}
.aer{background:rgba(255,60,60,.07);border:1px solid rgba(255,60,60,.2);color:#ff7070;}
.typing{display:flex;gap:4px;align-items:center;}
.dot{width:6px;height:6px;border-radius:50%;background:var(--muted2);animation:blink 1.2s infinite;}
.dot:nth-child(2){animation-delay:.2s;}.dot:nth-child(3){animation-delay:.4s;}
@keyframes blink{0%,80%,100%{opacity:.2;}40%{opacity:1;}}
.cpb{cursor:pointer;font-size:.75rem;padding:4px 10px;border-radius:8px;background:rgba(108,92,231,.12);color:#b2acff;border:1px solid rgba(108,92,231,.2);font-family:'DM Sans',sans-serif;font-weight:600;}
.ld{display:flex;align-items:center;justify-content:center;gap:.5rem;padding:2rem;color:var(--muted2);font-size:.85rem;}
.sp{width:18px;height:18px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .8s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
.empty{text-align:center;padding:3rem 1rem;color:var(--muted2);}
.admin-tabs{display:flex;gap:.4rem;margin-bottom:1.5rem;flex-wrap:wrap;}
.admin-tab{padding:.5rem 1.2rem;border-radius:8px;border:1px solid var(--border);background:none;color:var(--muted2);cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:600;transition:all .2s;}
.admin-tab.active{background:rgba(253,121,168,.15);color:#ffb3cc;border-color:rgba(253,121,168,.3);}
.user-row{display:flex;align-items:center;gap:.75rem;padding:.85rem 0;border-bottom:1px solid var(--border);flex-wrap:wrap;}
.user-row:last-child{border-bottom:none;}
.ua{width:36px;height:36px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;font-family:'Syne',sans-serif;}
.ua-info{flex:1;min-width:120px;}
.ua-actions{display:flex;gap:.35rem;flex-wrap:wrap;}
.ua-actions button{font-size:.68rem;padding:4px 9px;border-radius:6px;cursor:pointer;border:1px solid;font-family:'DM Sans',sans-serif;font-weight:600;transition:all .15s;}
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:10000;display:flex;align-items:center;justify-content:center;padding:1rem;}
.modal-box{background:var(--card);border:1px solid var(--border2);border-radius:16px;padding:2rem;width:100%;max-width:420px;box-shadow:0 20px 60px rgba(0,0,0,.5);}
.modal-title{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:700;margin-bottom:1.25rem;}
.modal-actions{display:flex;gap:.75rem;justify-content:flex-end;margin-top:1.5rem;}

/* ── V4 ADDITIONS ── */
.settings-tabs{display:flex;gap:.35rem;margin-bottom:1.75rem;flex-wrap:wrap;border-bottom:1px solid var(--border);padding-bottom:.75rem;}
.stab{padding:.45rem 1rem;border-radius:8px;font-size:.82rem;font-weight:600;cursor:pointer;background:none;border:1px solid transparent;color:var(--muted2);font-family:'DM Sans',sans-serif;transition:all .2s;}
.stab.active{background:rgba(108,92,231,.12);color:#b2acff;border-color:rgba(108,92,231,.3);}
.stab:hover{color:var(--text);}
.workspace-card{background:linear-gradient(135deg,rgba(0,206,201,.08),rgba(108,92,231,.06));border:1px solid rgba(0,206,201,.2);border-radius:var(--rl);padding:1.5rem;margin-bottom:1.25rem;}
.member-card{display:flex;align-items:center;gap:.75rem;padding:1rem;background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);margin-bottom:.6rem;transition:border-color .2s;}
.member-card:hover{border-color:var(--border2);}
.member-av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.95rem;flex-shrink:0;}
.member-info{flex:1;}.member-name{font-weight:600;font-size:.9rem;}.member-email{font-size:.73rem;color:var(--muted2);}
.member-role-badge{font-size:.68rem;padding:2px 8px;border-radius:10px;font-weight:700;}
.role-owner{background:rgba(253,203,110,.15);color:var(--gold);}.role-admin2{background:rgba(253,121,168,.12);color:#ffb3cc;}
.role-member{background:rgba(108,92,231,.12);color:#b2acff;}.role-viewer{background:rgba(74,74,106,.2);color:var(--muted2);}
.activity-item{display:flex;gap:.75rem;padding:.65rem 0;border-bottom:1px solid var(--border);}
.activity-item:last-child{border-bottom:none;}
.act-ico{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;background:rgba(108,92,231,.1);}
.act-info{flex:1;}.act-title{font-size:.83rem;font-weight:500;}.act-time{font-size:.7rem;color:var(--muted2);margin-top:2px;}
.export-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:1rem;}
.export-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:1.25rem;text-align:center;cursor:pointer;transition:all .2s;}
.export-card:hover{border-color:var(--border2);transform:translateY(-2px);}
.export-ico{font-size:2rem;margin-bottom:.5rem;}.export-name{font-size:.85rem;font-weight:600;margin-bottom:.25rem;}.export-desc{font-size:.73rem;color:var(--muted2);}
.integ-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:1rem;}
.integ-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:1.25rem;display:flex;flex-direction:column;gap:.75rem;}
.integ-header{display:flex;align-items:center;gap:.75rem;}
.integ-ico{width:40px;height:40px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.3rem;flex-shrink:0;}
.integ-name{font-weight:700;font-size:.9rem;}.integ-desc{font-size:.73rem;color:var(--muted2);}
.integ-status{display:flex;align-items:center;justify-content:space-between;}
.badge-connected{background:rgba(0,206,201,.1);color:var(--a3);font-size:.68rem;padding:2px 8px;border-radius:10px;font-weight:700;}
.badge-available{background:rgba(74,74,106,.15);color:var(--muted2);font-size:.68rem;padding:2px 8px;border-radius:10px;font-weight:700;}
.avatar-big{width:68px;height:68px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.7rem;font-weight:700;font-family:'Syne',sans-serif;flex-shrink:0;border:2px solid var(--border2);}
.info-row{display:flex;align-items:center;justify-content:space-between;padding:.75rem 0;border-bottom:1px solid var(--border);}
.info-row:last-child{border-bottom:none;}
.info-label{font-size:.73rem;color:var(--muted2);font-weight:500;}.info-value{font-size:.88rem;font-weight:600;}
.notif-row{display:flex;align-items:center;justify-content:space-between;padding:.85rem 0;border-bottom:1px solid var(--border);}
.notif-row:last-child{border-bottom:none;}
.notif-info .ntitle{font-size:.875rem;font-weight:600;}.notif-info .ndesc{font-size:.73rem;color:var(--muted2);margin-top:2px;}
.sw{width:40px;height:22px;border-radius:11px;cursor:pointer;position:relative;border:1px solid var(--border2);transition:background .2s;background:var(--bg3);}
.sw.on{background:var(--accent);border-color:var(--accent);}
.sw::after{content:'';position:absolute;top:2px;left:2px;width:16px;height:16px;border-radius:50%;background:#fff;transition:transform .2s;}
.sw.on::after{transform:translateX(18px);}
.bred{background:rgba(255,60,60,.15);color:#ff7070;border:1px solid rgba(255,60,60,.2);}

/* ── ENTERPRISE PLAN ── */
:root{--ent2:#00cec9;}
.plan-opt.sel-ent{border-color:var(--a3);background:rgba(0,206,201,.1);}
.pricing-card.enterprise{border-color:rgba(0,206,201,.35);box-shadow:0 0 50px rgba(0,206,201,.12);}
.pricing-badge-ent{position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#00cec9,#6c5ce7);color:#fff;font-size:.7rem;font-weight:700;padding:3px 12px;border-radius:20px;white-space:nowrap;}
.lock-ent{background:rgba(0,206,201,.12);color:var(--a3);}
.live.enterprise2{background:rgba(0,206,201,.1);color:var(--a3);border-color:rgba(0,206,201,.3);}
.live.enterprise2::before{background:var(--a3);}
.ent-banner{background:linear-gradient(135deg,rgba(0,206,201,.1),rgba(108,92,231,.06));border:1px solid rgba(0,206,201,.25);border-radius:var(--rl);padding:1.5rem;margin-bottom:1.5rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
/* JOIN WORKSPACE FORM */
.join-box{background:var(--card);border:1px solid var(--border2);border-radius:20px;padding:2rem;width:100%;max-width:460px;box-shadow:0 0 60px rgba(0,206,201,.15);}
.join-logo{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;text-align:center;margin-bottom:.3rem;}
.join-ws-name{text-align:center;font-size:1rem;font-weight:700;color:var(--a3);margin-bottom:.25rem;}
.join-ws-sub{text-align:center;font-size:.8rem;color:var(--muted2);margin-bottom:1.75rem;}
/* ENTERPRISE TOOLS */
.ent-tool-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;}
.ent-tool-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--rl);padding:1.5rem;transition:all .2s;}
.ent-tool-card:hover{border-color:rgba(0,206,201,.3);transform:translateY(-2px);}
.ent-tool-ico{font-size:2rem;margin-bottom:.6rem;}
.ent-tool-name{font-family:'Syne',sans-serif;font-size:.95rem;font-weight:700;margin-bottom:.3rem;}
.ent-tool-desc{font-size:.78rem;color:var(--muted2);line-height:1.5;}
.ent-badge{display:inline-block;margin-top:.6rem;font-size:.65rem;padding:2px 8px;border-radius:20px;font-weight:700;background:rgba(0,206,201,.1);color:var(--a3);}
.lock-ent-badge{position:absolute;top:.75rem;right:.75rem;font-size:.68rem;padding:2px 8px;border-radius:20px;border:1px solid rgba(0,206,201,.25);background:rgba(0,206,201,.08);color:var(--a3);}

/* ── ENTERPRISE EXTRA V4.1 ── */
.kpi-trend{display:inline-flex;align-items:center;gap:3px;font-size:.72rem;font-weight:700;padding:2px 7px;border-radius:20px;}
.kpi-up{background:rgba(0,206,201,.1);color:var(--a3);}
.kpi-down{background:rgba(255,60,60,.1);color:#ff7070;}
.kpi-flat{background:rgba(74,74,106,.15);color:var(--muted2);}
.report-period-tabs{display:flex;gap:.35rem;margin-bottom:1.25rem;}
.rptab{padding:.4rem 1rem;border-radius:8px;font-size:.78rem;font-weight:600;cursor:pointer;background:none;border:1px solid var(--border);color:var(--muted2);font-family:'DM Sans',sans-serif;transition:all .2s;}
.rptab.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.forecast-line{display:flex;align-items:center;justify-content:space-between;padding:.65rem 0;border-bottom:1px solid var(--border);}
.forecast-line:last-child{border-bottom:none;}
.budget-item{display:flex;align-items:center;gap:.75rem;padding:.75rem 0;border-bottom:1px solid var(--border);}
.budget-item:last-child{border-bottom:none;}
.budget-bar-wrap{flex:1;background:var(--bg3);border-radius:99px;height:8px;overflow:hidden;}
.budget-bar{height:8px;border-radius:99px;transition:width .5s;}
.crm-kanban{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:.75rem;}
.kanban-col{background:var(--bg3);border:1px solid var(--border);border-radius:var(--r);padding:.75rem;}
.kanban-col-title{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:.75rem;padding-bottom:.5rem;border-bottom:1px solid var(--border);}
.kanban-card{background:var(--card);border:1px solid var(--border);border-radius:8px;padding:.75rem;margin-bottom:.5rem;cursor:pointer;transition:all .2s;}
.kanban-card:hover{border-color:var(--border2);transform:translateY(-1px);}
.kanban-card-name{font-size:.83rem;font-weight:600;margin-bottom:.25rem;}
.kanban-card-co{font-size:.72rem;color:var(--muted2);}
.kanban-card-val{font-size:.78rem;font-weight:700;color:var(--a3);margin-top:.4rem;}
.payroll-row{display:flex;align-items:center;gap:.75rem;padding:.85rem 0;border-bottom:1px solid var(--border);}
.payroll-row:last-child{border-bottom:none;}
.payroll-grade{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.75rem;font-weight:700;}
.excel-import-zone{border:2px dashed rgba(0,206,201,.3);border-radius:var(--rl);padding:2rem;text-align:center;cursor:pointer;transition:all .2s;background:rgba(0,206,201,.03);}
.excel-import-zone:hover{border-color:var(--a3);background:rgba(0,206,201,.07);}
.excel-preview-table{width:100%;border-collapse:collapse;font-size:.78rem;max-height:300px;overflow:auto;display:block;}
.excel-preview-table th{background:rgba(108,92,231,.15);padding:6px 10px;text-align:left;color:#b2acff;font-size:.7rem;position:sticky;top:0;}
.excel-preview-table td{padding:5px 10px;border-bottom:1px solid rgba(255,255,255,.04);}
.tab-mini{display:flex;gap:.3rem;margin-bottom:1rem;flex-wrap:wrap;}
.tmtab{padding:.35rem .85rem;border-radius:6px;font-size:.75rem;font-weight:600;cursor:pointer;background:none;border:1px solid var(--border);color:var(--muted2);font-family:'DM Sans',sans-serif;transition:all .15s;}
.tmtab.active{background:rgba(108,92,231,.15);color:#b2acff;border-color:rgba(108,92,231,.3);}
</style>
</head>
<body>

<!-- AUTH -->
<div class="auth-overlay" id="authOverlay">
  <div class="auth-box">
    <div class="auth-logo">Pro<span>Hub</span></div>
    <div class="auth-sub">Suite Business tout-en-un — v4</div>
    <div class="auth-tabs">
      <div class="auth-tab active" onclick="switchAuthTab('login')">Connexion</div>
      <div class="auth-tab" onclick="switchAuthTab('register')">Inscription</div>
    </div>
    <div id="authErr" class="auth-err"></div>
    <div id="authOk" class="auth-ok"></div>
    <div id="loginForm" class="auth-form">
      <div class="auth-fg"><label class="auth-lbl">E-mail</label><input id="lEmail" type="email" placeholder="vous@exemple.fr"></div>
      <div class="auth-fg"><label class="auth-lbl">Mot de passe</label><input id="lPass" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
      <button class="btn bp" id="loginBtn" onclick="doLogin()" style="width:100%">Se connecter</button>
    </div>
    <div id="registerForm" class="auth-form" style="display:none">
      <div class="auth-fg"><label class="auth-lbl">Nom</label><input id="rName" placeholder="Jean Dupont"></div>
      <div class="auth-fg"><label class="auth-lbl">E-mail</label><input id="rEmail" type="email" placeholder="vous@exemple.fr"></div>
      <div class="auth-fg"><label class="auth-lbl">Mot de passe</label><input id="rPass" type="password" placeholder="••••••••"></div>
      <div class="auth-fg">
        <label class="auth-lbl">Plan</label>
        <div class="plan-grid">
          <div class="plan-opt sel" data-plan="free" onclick="selPlan(this)"><div class="pi">🆓</div><div class="pn">Gratuit</div><div class="pp">0 €</div></div>
          <div class="plan-opt" data-plan="premium" onclick="selPlan(this)"><div class="pi">⭐</div><div class="pn">Premium</div><div class="pp">20 €/mois</div></div>
          <div class="plan-opt" data-plan="premium2" onclick="selPlan(this)"><span class="pop-tag">🔥</span><div class="pi">💎</div><div class="pn">Premium+</div><div class="pp">35 €/mois</div></div>
          <div class="plan-opt" data-plan="enterprise" onclick="selPlan(this)" style="grid-column:1/-1;border-color:rgba(0,206,201,.3);"><span class="pop-tag" style="background:#00cec9">🏢</span><div class="pi">🏢</div><div class="pn">Entreprise</div><div class="pp">79 €/mois</div></div>
        </div>
      </div>
      <button class="btn bp" id="registerBtn" onclick="doRegister()" style="width:100%">Continuer →</button>
    </div>
    <div id="verifyForm" class="auth-form" style="display:none">
      <div style="text-align:center;margin-bottom:1rem"><div style="font-size:2rem;margin-bottom:.5rem">📧</div><div style="font-size:.95rem;font-weight:600;margin-bottom:.25rem">Vérifie ton email</div><div id="verifyEmailTxt" style="font-size:.8rem;color:var(--muted2)">Code envoyé</div></div>
      <div class="code-inputs">
        <input class="code-input" maxlength="1" oninput="moveCode(this,1)" onkeydown="backCode(event,this,0)">
        <input class="code-input" maxlength="1" oninput="moveCode(this,2)" onkeydown="backCode(event,this,1)">
        <input class="code-input" maxlength="1" oninput="moveCode(this,3)" onkeydown="backCode(event,this,2)">
        <input class="code-input" maxlength="1" oninput="moveCode(this,4)" onkeydown="backCode(event,this,3)">
        <input class="code-input" maxlength="1" oninput="moveCode(this,5)" onkeydown="backCode(event,this,4)">
        <input class="code-input" maxlength="1" oninput="moveCode(this,6)" onkeydown="backCode(event,this,5)">
      </div>
      <button class="btn bp" id="verifyBtn" onclick="doVerify()" style="width:100%">✅ Confirmer</button>
      <div style="text-align:center;margin-top:.75rem"><span style="font-size:.78rem;color:var(--muted2)">Pas reçu ? </span><span style="font-size:.78rem;color:var(--accent);cursor:pointer" onclick="doRegister()">Renvoyer</span></div>
    </div>
  </div>
</div>

<!-- JOIN WORKSPACE OVERLAY -->
<div class="auth-overlay" id="joinOverlay" style="display:none">
  <div class="join-box">
    <div class="join-logo">Pro<span style="color:var(--a2)">Hub</span></div>
    <div class="join-ws-name" id="joinWsName">Espace Entreprise</div>
    <div class="join-ws-sub" id="joinWsSub">Vous avez été invité à rejoindre cet espace</div>
    <div id="joinErr" class="auth-err"></div>
    <div id="joinOk" class="auth-ok"></div>
    <!-- Étape 1: compte existant ou création -->
    <div id="joinStep1" class="auth-form">
      <div style="display:flex;gap:.5rem;margin-bottom:1rem">
        <button class="btn bp" style="flex:1" onclick="showJoinLogin()">Se connecter</button>
        <button class="btn bo" style="flex:1" onclick="showJoinRegister()">Créer un compte</button>
      </div>
    </div>
    <!-- Login pour rejoindre -->
    <div id="joinLoginForm" class="auth-form" style="display:none">
      <div style="font-size:.8rem;color:var(--muted2);text-align:center;margin-bottom:1rem">Connectez-vous pour rejoindre l'espace</div>
      <div class="auth-fg"><label class="auth-lbl">E-mail</label><input id="joinLEmail" type="email" placeholder="vous@exemple.fr"></div>
      <div class="auth-fg"><label class="auth-lbl">Mot de passe</label><input id="joinLPass" type="password" placeholder="••••••••" onkeydown="if(event.key==='Enter')joinLogin()"></div>
      <button class="btn bp" id="joinLoginBtn" onclick="joinLogin()" style="width:100%">Se connecter et rejoindre →</button>
      <div style="text-align:center;margin-top:.5rem"><span style="font-size:.78rem;color:var(--accent);cursor:pointer" onclick="showJoinRegister()">Pas de compte ? Créer</span></div>
    </div>
    <!-- Register pour rejoindre -->
    <div id="joinRegisterForm" class="auth-form" style="display:none">
      <div style="font-size:.8rem;color:var(--muted2);text-align:center;margin-bottom:1rem">Créez un compte gratuit pour rejoindre l'espace</div>
      <div class="auth-fg"><label class="auth-lbl">Nom</label><input id="joinRName" placeholder="Jean Dupont"></div>
      <div class="auth-fg"><label class="auth-lbl">Mot de passe</label><input id="joinRPass" type="password" placeholder="••••••••"></div>
      <button class="btn bp" id="joinRegisterBtn" onclick="joinRegister()" style="width:100%">Créer mon compte →</button>
