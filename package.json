<script>
const API={async req(method,url,body,auth=true){const h={'Content-Type':'application/json'};if(auth)h['Authorization']='Bearer '+localStorage.getItem('ph_token');const r=await fetch(url,{method,headers:h,body:body?JSON.stringify(body):undefined});return r.json();},get:u=>API.req('GET',u),post:(u,b,a=true)=>API.req('POST',u,b,a),patch:(u,b)=>API.req('PATCH',u,b),del:u=>API.req('DELETE',u)};
let currentUser=null,pendingReg=null,selectedPlan='free',billingYearly=false,adminUsers=[],modalTargetId=null;
let adminChPlan,adminChReg,adminChRev;

// AUTH
function switchAuthTab(t){document.querySelectorAll('.auth-tab').forEach((x,i)=>x.classList.toggle('active',(t==='login'&&i===0)||(t==='register'&&i===1)));['loginForm','registerForm','verifyForm'].forEach(id=>document.getElementById(id).style.display='none');document.getElementById(t==='login'?'loginForm':'registerForm').style.display='flex';clearAuthMsgs();}
function selPlan(el){document.querySelectorAll('.plan-opt').forEach(p=>p.classList.remove('sel','sel-pp2','sel-ent'));const plan=el.dataset.plan;el.classList.add(plan==='premium2'?'sel-pp2':plan==='enterprise'?'sel-ent':'sel');selectedPlan=plan;}
function showAuthErr(m){const e=document.getElementById('authErr');e.textContent=m;e.classList.add('show');document.getElementById('authOk').classList.remove('show');}
function showAuthOk(m){const e=document.getElementById('authOk');e.textContent=m;e.classList.add('show');document.getElementById('authErr').classList.remove('show');}
function clearAuthMsgs(){['authErr','authOk'].forEach(id=>document.getElementById(id).classList.remove('show'));}
function setBtn(id,loading,txt){const b=document.getElementById(id);b.disabled=loading;b.textContent=loading?'⏳...':txt;}

async function doLogin(){const e=document.getElementById('lEmail').value.trim(),p=document.getElementById('lPass').value;if(!e||!p){showAuthErr('Remplis tous les champs.');return;}setBtn('loginBtn',true,'Se connecter');const r=await API.post('/api/auth/login',{email:e,password:p},false);setBtn('loginBtn',false,'Se connecter');if(r.error){showAuthErr(r.error);return;}localStorage.setItem('ph_token',r.token);loadApp(r.user);}

async function doRegister(){const n=document.getElementById('rName').value.trim(),e=document.getElementById('rEmail').value.trim(),p=document.getElementById('rPass').value;if(!n||!e||!p){showAuthErr('Remplis tous les champs.');return;}setBtn('registerBtn',true,'Continuer →');const r=await API.post('/api/auth/register',{name:n,email:e,password:p},false);setBtn('registerBtn',false,'Continuer →');if(r.error){showAuthErr(r.error);return;}pendingReg={name:n,email:e,password:p,plan:selectedPlan};['loginForm','registerForm'].forEach(id=>document.getElementById(id).style.display='none');document.getElementById('verifyForm').style.display='flex';document.getElementById('verifyEmailTxt').textContent='Code envoyé sur '+e;showAuthOk('📧 Code envoyé ! Vérifie ta boîte mail.');document.querySelectorAll('#verifyForm .code-input')[0].focus();}

function moveCode(el,next){if(el.value&&next<=6){const inputs=document.querySelectorAll('#verifyForm .code-input');if(inputs[next])inputs[next].focus();}checkAutoVerify();}
function backCode(e,el,prev){if(e.key==='Backspace'&&!el.value&&prev>=0)document.querySelectorAll('#verifyForm .code-input')[prev].focus();}
function checkAutoVerify(){const code=[...document.querySelectorAll('#verifyForm .code-input')].map(i=>i.value).join('');if(code.length===6)doVerify();}

async function doVerify(){const code=[...document.querySelectorAll('#verifyForm .code-input')].map(i=>i.value).join('');if(code.length!==6){showAuthErr('Entre le code à 6 chiffres.');return;}setBtn('verifyBtn',true,'✅ Confirmer');const{name,email,password,plan}=pendingReg;const r=await API.post('/api/auth/verify-register',{name,email,password,code},false);setBtn('verifyBtn',false,'✅ Confirmer');if(r.error){showAuthErr(r.error);document.querySelectorAll('#verifyForm .code-input').forEach(i=>i.value='');document.querySelectorAll('#verifyForm .code-input')[0].focus();return;}localStorage.setItem('ph_token',r.token);if(plan==='premium'||plan==='premium2'||plan==='enterprise'){loadApp(r.user);setTimeout(()=>startCheckout(plan+'_month'),500);}else loadApp(r.user);}

function doLogout(){localStorage.removeItem('ph_token');currentUser=null;document.getElementById('authOverlay').style.display='flex';document.getElementById('appLayout').style.display='none';switchAuthTab('login');}

async function startCheckout(plan){const r=await API.post('/api/payment/create-checkout',{plan});if(r.error){alert('Erreur: '+r.error);return;}if(r.url)window.location.href=r.url;}

function updateUserUI(){
  const user=currentUser;if(!user)return;
  document.getElementById('userAv').textContent=user.name.charAt(0).toUpperCase();
  document.getElementById('userName').textContent=user.name;
  document.getElementById('userEmail').textContent=user.email;
  const rMap={free:'Gratuit',premium:'Premium ⭐',premium2:'Premium+ 💎',enterprise:'Entreprise 🏢',admin:'Admin 👑'};
  const rCls={free:'free',premium:'premium',premium2:'premium2',enterprise:'enterprise',admin:'admin'};
  const rb=document.getElementById('roleBadge');rb.className='live '+(rCls[user.role]||'free');rb.textContent=rMap[user.role]||'Gratuit';
  const isPrem=hasPremium(user),isPP2=hasPP2(user),isAdmin=user.role==='admin',isEnt=isEnterprise(user);
  ['lockCrypto','lockRentab','lockPosts','lockTva','lockContrats'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.display=isPrem?'none':'inline';});
  ['lockEquipe','lockEmails','lockAgenda','lockNotes','lockKpis','lockRecurrents','lockWorkspace'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.display=isPP2?'none':'inline';});
  document.getElementById('adminNav').style.display=isAdmin?'block':'none';
  document.getElementById('adminLink').style.display=isAdmin?'flex':'none';
  const entNav=document.getElementById('entNav');if(entNav)entNav.style.display=isEnt?'block':'none';
  ['crmLink','hrLink','reportingLink','budgetEntLink','excelLink'].forEach(id=>{const el=document.getElementById(id);if(el)el.style.display=isEnt?'flex':'none';});
  document.getElementById('upgradeBanner').style.display=isPrem?'none':'flex';
  document.getElementById('pp2UpgradeBanner').style.display=(isPrem&&!isPP2&&!isEnt)?'flex':'none';
}
async function loadApp(user){currentUser=user;document.getElementById('authOverlay').style.display='none';document.getElementById('appLayout').style.display='grid';updateUserUI();renderHomeModules();rBudget();calcFL();calcDS();calcINV();renderDevis();renderProd();addLine();initTeam();initAgenda();initNotes();initKpis();initRecurrents();initWorkspace();renderSettingsProfile();initCRM();initHR();initReporting();initBudgetEnt();loadAnnouncements();go('accueil',document.querySelector('.ni'));if(isAdmin)loadAdminData();const params=new URLSearchParams(window.location.search);if(params.get('session_id')){const v=await API.get('/api/payment/verify/'+params.get('session_id'));if(v.success){currentUser.role=v.role;localStorage.setItem('ph_token',v.token);window.history.replaceState({},'','/');loadApp(currentUser);addBotMsg('🎉 Paiement confirmé ! Compte '+(v.role==='enterprise'?'Entreprise 🏢 ':v.role==='premium2'?'Premium+':'Premium')+' activé.');}}};

function hasPremium(u){return u&&(u.role==='premium'||u.role==='premium2'||u.role==='enterprise'||u.role==='admin');}
function hasPP2(u){return u&&(u.role==='premium2'||u.role==='enterprise'||u.role==='admin');}
function isEnterprise(u){return u&&(u.role==='enterprise'||u.role==='admin');}


// NAVIGATION
function go(id,el){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.querySelectorAll('.ni').forEach(n=>n.classList.remove('active'));const pg=document.getElementById('page-'+id);if(pg)pg.classList.add('active');if(el)el.classList.add('active');if(id==='crypto'&&!crL)loadCrypto();if(id==='rentab'){calcFL();calcDS();calcINV();}if(id==='tva')calcTVA();if(id==='admin')loadAdminData();if(id==='settings')renderSettingsProfile();if(id==='crm')renderCRM();if(id==='hr')renderHR();if(id==='reporting')renderReporting();if(id==='budgetent')renderBudgetEnt();if(id==='excel')swExcelTab('import',null);}
function tryGo(id,minRole,el){const ok=(minRole==='premium'?hasPremium(currentUser):hasPP2(currentUser));if(!ok){go('tarifs',null);return;}go(id,el);}

// TARIFS
function toggleBilling(){billingYearly=!billingYearly;document.getElementById('billingToggle').classList.toggle('on',billingYearly);document.getElementById('premiumPrice').innerHTML=billingYearly?'200 €<span>/an</span>':'20 €<span>/mois</span>';document.getElementById('premium2Price').innerHTML=billingYearly?'300 €<span>/an</span>':'35 €<span>/mois</span>';document.getElementById('enterprisePrice').innerHTML=billingYearly?'790 €<span style="-webkit-text-fill-color:var(--muted2)">/an</span>':'79 €<span style="-webkit-text-fill-color:var(--muted2)">/mois</span>';document.getElementById('premiumYearly').textContent=billingYearly?'Économise 40 € par rapport au mensuel':'ou 200 €/an — économise 40 €';document.getElementById('premium2Yearly').textContent=billingYearly?'Économise 120 € par rapport au mensuel':'ou 300 €/an — économise 120 €';document.getElementById('enterpriseYearly').textContent=billingYearly?'Économise 158 € par rapport au mensuel':'ou 790 €/an — économise 158 €';}

// ══════ JOIN WORKSPACE ══════════════════════════════════════════════
let joinCtx=null; // {wsId,wsName,inviteEmail,inviteRole}

window.addEventListener('DOMContentLoaded',async()=>{
  const t=localStorage.getItem('ph_token');
  // Check for workspace invite link ?join=wsId&email=x&role=y&name=WsName
  const params=new URLSearchParams(window.location.search);
  if(params.get('join')){
    joinCtx={wsId:params.get('join'),wsName:decodeURIComponent(params.get('wname')||'Espace Entreprise'),inviteEmail:decodeURIComponent(params.get('email')||''),inviteRole:params.get('role')||'member'};
    window.history.replaceState({},'','/');
    document.getElementById('joinWsName').textContent=joinCtx.wsName;
    document.getElementById('joinWsSub').textContent='Rôle attribué : '+(joinCtx.inviteRole==='admin2'?'Admin':joinCtx.inviteRole==='viewer'?'Lecteur':'Membre');
    if(joinCtx.inviteEmail)document.getElementById('joinLEmail').value=joinCtx.inviteEmail;
    document.getElementById('joinOverlay').style.display='flex';
    return;
  }
  if(t){const r=await API.get('/api/auth/me');if(r.id)loadApp(r);else localStorage.removeItem('ph_token');}
});

function showJoinLogin(){['joinStep1','joinRegisterForm','joinVerifyForm'].forEach(id=>document.getElementById(id).style.display='none');document.getElementById('joinLoginForm').style.display='flex';}
function showJoinRegister(){['joinStep1','joinLoginForm','joinVerifyForm'].forEach(id=>document.getElementById(id).style.display='none');document.getElementById('joinRegisterForm').style.display='flex';}

async function joinLogin(){
  const e=(document.getElementById('joinLEmail').value||joinCtx?.inviteEmail||'').trim();
  const p=document.getElementById('joinLPass').value;
  if(!e||!p){document.getElementById('joinErr').textContent='Email et mot de passe requis.';document.getElementById('joinErr').classList.add('show');return;}
  document.getElementById('joinLoginBtn').disabled=true;
  const r=await API.post('/api/auth/login',{email:e,password:p},false);
  document.getElementById('joinLoginBtn').disabled=false;
  if(r.error){document.getElementById('joinErr').textContent=r.error;document.getElementById('joinErr').classList.add('show');return;}
  localStorage.setItem('ph_token',r.token);
  document.getElementById('joinOverlay').style.display='none';
  await loadApp(r.user);
  // Add to workspace
  if(joinCtx)completeJoinWorkspace(r.user);
}

let pendingJoinReg=null;
async function joinRegister(){
  const n=document.getElementById('joinRName').value.trim();
  const e=(joinCtx?.inviteEmail||'').trim()||prompt('Entrez votre email :');
  const p=document.getElementById('joinRPass').value;
  if(!n||!e||!p){document.getElementById('joinErr').textContent='Remplis tous les champs.';document.getElementById('joinErr').classList.add('show');return;}
  document.getElementById('joinRegisterBtn').disabled=true;
  const r=await API.post('/api/auth/register',{name:n,email:e,password:p},false);
  document.getElementById('joinRegisterBtn').disabled=false;
  if(r.error){document.getElementById('joinErr').textContent=r.error;document.getElementById('joinErr').classList.add('show');return;}
  pendingJoinReg={name:n,email:e,password:p};
  ['joinStep1','joinLoginForm','joinRegisterForm'].forEach(id=>document.getElementById(id).style.display='none');
  document.getElementById('joinVerifyForm').style.display='flex';
  document.getElementById('joinOk').textContent='📧 Code envoyé sur '+e;document.getElementById('joinOk').classList.add('show');
}

function moveJoinCode(el,next){if(el.value&&next<=6){const inputs=document.querySelectorAll('#joinCodeInputs .code-input');if(inputs[next])inputs[next].focus();}checkJoinAuto();}
function backJoinCode(e,el,prev){if(e.key==='Backspace'&&!el.value&&prev>=0)document.querySelectorAll('#joinCodeInputs .code-input')[prev].focus();}
function checkJoinAuto(){const code=[...document.querySelectorAll('#joinCodeInputs .code-input')].map(i=>i.value).join('');if(code.length===6)joinVerify();}

async function joinVerify(){
  const code=[...document.querySelectorAll('#joinCodeInputs .code-input')].map(i=>i.value).join('');
  if(code.length!==6)return;
  document.getElementById('joinVerifyBtn').disabled=true;
  const r=await API.post('/api/auth/verify-register',{...pendingJoinReg,code},false);
  document.getElementById('joinVerifyBtn').disabled=false;
  if(r.error){document.getElementById('joinErr').textContent=r.error;document.getElementById('joinErr').classList.add('show');document.querySelectorAll('#joinCodeInputs .code-input').forEach(i=>i.value='');return;}
  localStorage.setItem('ph_token',r.token);
  document.getElementById('joinOverlay').style.display='none';
  await loadApp(r.user);
  if(joinCtx)completeJoinWorkspace(r.user);
}

function completeJoinWorkspace(user){
  // Find the workspace owner and add this user as member
  // In this local-first setup, we show a success message and add to local ws
  const uid=joinCtx.wsId;
  // We store a "joined workspaces" list for this user
  const joined=JSON.parse(localStorage.getItem('ph_joined_ws_'+user.id)||'[]');
  if(!joined.find(j=>j.wsId===joinCtx.wsId)){
    joined.push({wsId:joinCtx.wsId,wsName:joinCtx.wsName,role:joinCtx.inviteRole,joinedAt:new Date().toISOString()});
    localStorage.setItem('ph_joined_ws_'+user.id,JSON.stringify(joined));
  }
  addBotMsg('🎉 Bienvenue dans l\'espace "'+joinCtx.wsName+'" ! Tu as rejoint en tant que '+(joinCtx.inviteRole==='admin2'?'Admin':'Membre')+'.');
  joinCtx=null;
}

