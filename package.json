function genPost(){const sv=document.getElementById('posv').value||'mon service',ar=document.getElementById('poar').value||'résultats garantis',ad=document.getElementById('poad').value||'entrepreneurs',tn=document.getElementById('poton').value,h=sv.replace(/\s+/g,'').toLowerCase();const ps={'Professionnel':`🎯 À tous les ${ad} :\n\nVous cherchez ${sv} ?\n\n✅ ${ar}\n✅ Accompagnement personnalisé\n✅ Résultats mesurables\n\n📩 DM ou lien en bio.\n\n#${h} #entrepreneur #business`,'Motivant':`🔥 Ce que j'ai appris en travaillant avec des ${ad} :\n\n${ar}.\n\nL'action bat toujours l'hésitation.\n\nTu veux ${sv} ?\n\n👇 "GO" en commentaire.`,'Humour':`POV : T'as besoin de ${sv} 😅\n\nMais t'as pas encore sauté le pas...\n\nSpoiler : ${ar} 🎯\n\n📩 DM ouvert !`,'Urgence':`⚠️ ATTENTION — PLACES LIMITÉES ce mois !\n\n→ ${ar}\n→ ${sv} de qualité\n→ Résultats rapides\n\n📩 "URGENT" en DM MAINTENANT.`,'Storytelling':`Un client m'a dit "c'est trop cher".\n\n3 semaines après, il me rappelait...\n\nRésultat ? ${ar}\n\nC'est ça, ${sv}.\n\n📩 Ton histoire commence ici.`};document.getElementById('pout').textContent=ps[tn]||ps['Professionnel'];}
